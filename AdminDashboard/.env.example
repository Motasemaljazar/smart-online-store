# Database Configuration
ConnectionStrings__DefaultConnection=Server=mysql;Port=3306;Database=srds;User=root;Password=your_secure_password;Allow User Variables=true;SslMode=None;CharSet=utf8mb4;TreatTinyAsBoolean=true;AllowPublicKeyRetrieval=True;

# Security Settings
Security__AdminApiKey=change_this_to_a_long_random_string_min_32_chars
Security__DriverTokenSecret=change_this_to_a_long_random_string_min_32_chars
Security__DriverTokenMinutes=1440

# Initial Admin User (Created on first startup)
InitialAdmin__Email=admin@example.com
InitialAdmin__Password=ChangeThisToAStrongPassword123!

# CORS Configuration (Comma-separated for multiple origins)
Cors__AllowedOrigins__0=https://yourdomain.com
Cors__AllowedOrigins__1=https://www.yourdomain.com

# Firebase Configuration
Firebase__ServiceAccountPath=/app/firebase-service-account.json

# ASP.NET Core Environment
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:8080
