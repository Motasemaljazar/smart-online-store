@page
@model AdminDashboard.Pages.Admin.AdminPageModel

<div class="admin-page-header">
  <div class="page-icon"><i class="bi bi-truck"></i></div>
  <div>
    <h1 class="page-title">الطلبات المسلمة</h1>
    <p class="page-subtitle">الطلبات التي تم توصيلها (تم التسليم)</p>
  </div>
</div>

<div class="admin-card">
  <div class="admin-card-header">
    <span>قائمة الطلبات المسلمة</span>
    <div class="d-flex gap-2 align-items-center flex-wrap">
      <button class="btn btn-sm btn-primary" id="btnRefresh"><i class="bi bi-arrow-clockwise me-1"></i>تحديث</button>
    </div>
  </div>
  <div class="admin-card-body p-0">
    <div class="table-responsive orders-table-responsive">
      <table class="table table-hover table-sm align-middle mb-0 orders-data-table" id="tbl">
        <thead class="table-light">
          <tr>
            <th class="order-col-id">#</th>
            <th class="order-col-status">الحالة</th>
            <th class="order-col-total">المبلغ</th>
            <th class="order-col-km">كم</th>
            <th class="order-col-customer">الزبون</th>
            <th class="order-col-driver">السائق</th>
            <th class="order-col-actions text-center">إجراءات</th>
          </tr>
        </thead>
        <tbody></tbody>
      </table>
    </div>
  </div>
</div>

<div class="modal fade" id="modalDeliveredOrderActions" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered modal-sm">
    <div class="modal-content">
      <div class="modal-header py-2">
        <h6 class="modal-title"><i class="bi bi-list-ul me-2"></i>إجراءات الطلب</h6>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body p-2" id="modalDeliveredOrderActionsBody"></div>
    </div>
  </div>
</div>

@section Scripts {
<script>
const tblBody = document.querySelector('#tbl tbody');
const btnRefresh = document.getElementById('btnRefresh');
let _deliveredOrdersList = [];
let _deliveredOrderActionsModal = null;

const statusName = (s)=>['طلب جديد','مؤكد','قيد التجهيز','جاهز للشحن','مع السائق','تم التوصيل','تم الإلغاء'][s] || s;

window.openDeliveredOrderActionsPopup = function(orderId){
  const o = _deliveredOrdersList.find(x => x.id === orderId);
  if(!o){ alert('الطلب غير موجود'); return; }
  const hasLatLng = (typeof o.deliveryLat === 'number' && o.deliveryLat && typeof o.deliveryLng === 'number' && o.deliveryLng);
  const body = document.getElementById('modalDeliveredOrderActionsBody');
  body.innerHTML = `
    <div class="d-grid gap-1">
      <button type="button" class="btn btn-sm btn-outline-secondary text-start" data-action="map" data-order-id="${o.id}" ${!hasLatLng?'disabled':''}><i class="bi bi-geo-alt me-2"></i>خريطة</button>
      <button type="button" class="btn btn-sm btn-outline-secondary text-start" data-action="chat" data-order-id="${o.id}"><i class="bi bi-chat-dots me-2"></i>دردشة</button>
      ${o.customerPhone ? `<a class="btn btn-sm btn-outline-secondary text-start" href="tel:${String(o.customerPhone).replace(/"/g,'&quot;')}" role="button"><i class="bi bi-telephone me-2"></i>اتصال</a>` : ''}
      <hr class="my-2"/>
      <button type="button" class="btn btn-sm btn-outline-danger text-start" data-action="delete" data-order-id="${o.id}"><i class="bi bi-trash me-2"></i>حذف</button>
    </div>`;
  body.querySelectorAll('[data-action]').forEach(btn=>{
    btn.addEventListener('click', function(){
      const act = this.getAttribute('data-action');
      const id = parseInt(this.getAttribute('data-order-id'),10);
      const order = _deliveredOrdersList.find(x=>x.id===id);
      if(!order) return;
      if(this.disabled) return;
      if(_deliveredOrderActionsModal) _deliveredOrderActionsModal.hide();
      if(act==='map') openMap(order.deliveryLat ?? 0, order.deliveryLng ?? 0);
      else if(act==='chat') openChat(order.customerId);
      else if(act==='delete') deleteOrder(id);
    });
  });
  if(!_deliveredOrderActionsModal) _deliveredOrderActionsModal = new bootstrap.Modal(document.getElementById('modalDeliveredOrderActions'));
  _deliveredOrderActionsModal.show();
};

async function load(){
  const res = await fetch('/api/admin/orders?deliveredOnly=true');
  if(!res.ok){ tblBody.innerHTML='<tr><td colspan="8">فشل تحميل الطلبات</td></tr>'; return; }
  let list = [];
  try { list = await res.json(); }
  catch(e){
    console.error('delivered orders json parse failed', e);
    tblBody.innerHTML='<tr><td colspan="8">تعذر قراءة البيانات. أعد تسجيل الدخول ثم حدّث الصفحة.</td></tr>';
    return;
  }
  const distanceText = (o)=> (o.deliveryDistanceKm != null && o.deliveryDistanceKm > 0 ? Number(o.deliveryDistanceKm).toFixed(2) : '—');

  if (list.length === 0) {
    tblBody.innerHTML = '<tr><td colspan="8" class="text-center text-muted py-5">لا توجد طلبات مسلمة حالياً</td></tr>';
    return;
  }

  _deliveredOrdersList = list;
  tblBody.innerHTML = list.map(o=>`<tr>
    <td data-label="الترقيم">${o.id}</td>
    <td data-label="الحالة"><span class="badge bg-success">${statusName(o.currentStatus)}</span></td>
    <td data-label="المبلغ">${o.total != null ? Number(o.total).toFixed(2) : '—'}</td>
    <td data-label="كم">${distanceText(o)}</td>
    <td data-label="الزبون">
      <div class="fw-semibold">${o.customerName ?? ('#'+o.customerId)}</div>
      <div class="text-muted" style="font-size:12px">${o.customerPhone ?? ''}</div>
    </td>
    <td data-label="السائق">${o.driverId ?? '-'}</td>
    <td class="text-center order-col-actions" data-label="إجراءات">
      <button class="btn btn-sm btn-outline-primary" type="button" onclick="openDeliveredOrderActionsPopup(${o.id})" title="إجراءات">
        <i class="bi bi-three-dots-vertical me-1"></i>إجراءات
      </button>
    </td>
  </tr>`).join('');
}

async function deleteOrder(orderId){
  if(!confirm('⚠️ هل أنت متأكد من حذف الطلب نهائياً؟\n\nسيتم حذف الطلب من التقارير والإيرادات وجميع البيانات المتعلقة به.\n\nهذا الإجراء لا يمكن التراجع عنه!')) return;
  try{
    const res = await fetch(`/api/admin/order/${orderId}/delete`, { method:'DELETE' });
    if(!res.ok){
      let msg = 'فشل حذف الطلب';
      try{ const j = await res.json(); if(j && j.message) msg = j.message; }catch(_){ }
      alert(msg);
      return;
    }
    await load();
    if(window.adminToast) window.adminToast('تم الحذف', `تم حذف الطلب #${orderId} نهائياً`, 'warn');
  }catch(e){
    console.error(e);
    alert('حدث خطأ أثناء الحذف');
  }
}

window.openChat = function(customerId){
  window.location.href = `/Admin/Chats?customerId=${customerId}`;
};

window.openMap = (lat, lng)=>{
  try {
    if(!lat || !lng) return;
    const q = `${lat},${lng}`;
    const url = `https://www.google.com/maps?q=${encodeURIComponent(q)}`;
    window.open(url, "_blank");
  } catch(e) {
    console.error(e);
  }
};

btnRefresh.addEventListener('click', load);

const hub = new signalR.HubConnectionBuilder().withUrl('/hubs/notify').withAutomaticReconnect().build();
hub.start().catch(console.error);
hub.on('order_status', ()=>load());

load();
setInterval(()=>load(), 15000);
</script>
}
