@page
@model AdminDashboard.Pages.Admin.AdminPageModel

<h2 class="h4 mb-3"><i class="bi bi-chat-left-text me-2"></i>شكاوي الزبائن</h2>

<div class="row g-3">
  <div class="col-12 col-lg-5" id="threadsCol">
    <div class="card p-3">
      <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
        <div class="fw-semibold">قائمة الشكاوي</div>
        <div class="d-flex gap-1">
          <button class="btn btn-sm btn-outline-primary" id="btnRefresh">تحديث</button>
        </div>
      </div>
      <div class="mt-3">
        <input class="form-control form-control-sm" id="txtSearch" placeholder="بحث بالاسم/الهاتف/الشكوى..." />
        <div class="d-flex align-items-center justify-content-between mt-2">
          <div class="form-check">
            <input class="form-check-input" type="checkbox" id="chkUnread" />
            <label class="form-check-label small" for="chkUnread">غير مقروء فقط</label>
          </div>
          <select class="form-select form-select-sm" id="selSort" style="max-width: 180px;">
            <option value="latest" selected>الأحدث</option>
            <option value="unread">غير المقروء أولاً</option>
          </select>
        </div>
      </div>

      <div id="threads" class="mt-3"></div>
    </div>
  </div>
  <div class="col-12 col-lg-7">
    <div class="card p-3">
      <div class="d-flex justify-content-between align-items-center">
        <div class="fw-semibold">تفاصيل الشكوى</div>
        <div class="d-flex align-items-center gap-2">
          <span class="badge text-bg-warning d-none" id="badgeBlocked">موقوف</span>
          <button class="btn btn-sm btn-outline-secondary d-none" id="btnArchive" title="إزالة من قائمة الشكاوي">
            <i class="bi bi-archive me-1"></i>إزالة
          </button>
          <button class="btn btn-sm btn-outline-danger d-none" id="btnToggleBlock">إيقاف</button>
        </div>
      </div>
      <div id="customerInfo" class="mt-3"></div>
      <div id="messages" class="mt-3" style="height:40vh; overflow:auto;"></div>
      <div class="input-group mt-3">
        <input class="form-control" id="replyText" placeholder="اكتب الرد — سيصل كإشعار فوري للزبون..." />
        <button class="btn btn-primary" id="btnSend"><i class="bi bi-send me-1"></i>رد وإشعار</button>
      </div>
      <div class="d-flex gap-2 mt-2">
        <button class="btn btn-outline-secondary btn-sm" id="btnAiSuggest" title="اقتراح رد ذكي بالذكاء الاصطناعي">
          <span class="btn-icon">🤖</span>
          <span class="btn-text ms-1">اقتراح رد AI</span>
          <span class="spinner-border spinner-border-sm d-none ms-1" id="aiSuggestSpinner"></span>
        </button>
        <div class="vr"></div>
        <div class="form-check form-switch d-flex align-items-center gap-2 mb-0" title="تفعيل/تعطيل الرد التلقائي بالذكاء الاصطناعي على رسائل الزبائن">
          <input class="form-check-input" type="checkbox" id="chkAutoReply" role="switch" checked>
          <label class="form-check-label small text-muted" for="chkAutoReply">
            <span id="autoReplyLabel">🤖 رد تلقائي</span>
          </label>
        </div>
      </div>
      <div class="small text-muted mt-2" id="status"></div>
    </div>
  </div>
</div>

@section Scripts {
<script>
let currentThreadId = null;
const customerFilter = new URLSearchParams(window.location.search).get('customerId');
const threadsDiv = document.getElementById('threads');
const messagesDiv = document.getElementById('messages');
const customerInfoDiv = document.getElementById('customerInfo');
const status = document.getElementById('status');
const badgeBlocked = document.getElementById('badgeBlocked');
const btnToggleBlock = document.getElementById('btnToggleBlock');
const txtSearch = document.getElementById('txtSearch');
const chkUnread = document.getElementById('chkUnread');
const selSort = document.getElementById('selSort');
let currentCustomerId = customerFilter ? parseInt(customerFilter, 10) : null;
let isChatBlocked = false;
let allThreads = [];

function _fmtTime(iso){
  if(!iso) return '';
  try{
    return new Date(iso).toLocaleString('ar', { hour: '2-digit', minute: '2-digit', year:'numeric', month:'2-digit', day:'2-digit' });
  } catch { return ''; }
}

function _escapeHtml(s){
  return (s ?? '').toString().replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}


function renderCustomerInfo(data){
  if(!customerInfoDiv) return;
  if(!data || !data.customer){ customerInfoDiv.innerHTML=''; return; }
  const c = data.customer;
  const orders = Array.isArray(data.orders) ? data.orders : [];

  const header = `
    <div class="card border-0 shadow-sm">
      <div class="card-body p-3">
        <div class="d-flex justify-content-between align-items-start">
          <div>
            <div class="fw-semibold">${_escapeHtml(c.name || ('زبون #' + c.id))}</div>
            <div class="text-muted small">${_escapeHtml(c.phone || '')}</div>
          </div>
          ${c.isChatBlocked ? '<span class="badge text-bg-warning">موقوف</span>' : ''}
        </div>
        <div class="text-muted small mt-1">إنشاء الحساب: ${_fmtTime(c.createdAtUtc)}</div>
        <hr class="my-2"/>
        <div class="fw-semibold mb-2">كل الطلبات + التقييم</div>
        ${renderOrdersTable(orders)}
      </div>
    </div>`;

  customerInfoDiv.innerHTML = header;
}

        function renderOrdersTable(orders){
          if(!orders.length) return '<div class="text-muted small">لا يوجد طلبات بعد</div>';

          return `
            <div class="table-responsive" style="max-height: 30vh; overflow:auto;">
              <table class="table table-sm align-middle mb-0">
                <thead>
                  <tr>
                    <th style="white-space:nowrap">رقم</th>
                    <th style="white-space:nowrap">الحالة</th>
                    <th style="white-space:nowrap">الإجمالي</th>
                    <th style="white-space:nowrap">التاريخ</th>
                    <th>التفاصيل + التقييم</th>
                  </tr>
                </thead>
                <tbody>
                  ${orders.map(o=>{
                    const items = Array.isArray(o.items) ? o.items : [];

                    // تصفية البيانات التقنية الطويلة
                    const itemsTxt = items.map(i=>{
                      // عرض فقط الاسم والكمية
                      let display = `${_escapeHtml(i.name)} × ${i.qty}`;

                      // تجاهل خيارات JSON الطويلة والبيانات الفنية
                      // فقط نعرض ملاحظات قصيرة معقولة
                      if(i.note && i.note.length < 50 && i.note !== 'null' && !i.note.includes('"variantId"') && !i.note.includes('"addons"')) {
                        display += ` — ${_escapeHtml(i.note)}`;
                      }
                      return display;
                    }).join('<br/>');

                    const r = o.orderRating;
                    const rateTxt = r ? `⭐ متجر: ${r.storeRate ?? '-'} | ⭐ سائق: ${r.driverRate ?? '-'}<br/><span class="text-muted small">${_escapeHtml(r.comment ?? '')}</span>` : '<span class="text-muted">— بدون تقييم —</span>';
                    return `
                      <tr>
                        <td>#${o.id}</td>
                        <td>${_escapeHtml(o.status)}</td>
                        <td>${Number(o.total ?? 0).toFixed(0)} ل.س</td>
                        <td>${_fmtTime(o.createdAtUtc)}</td>
                        <td>
                          <div class="small">${itemsTxt || '<span class="text-muted">—</span>'}</div>
                          <div class="mt-1">${rateTxt}</div>
                        </td>
                      </tr>`;
                  }).join('')}
                </tbody>
              </table>
            </div>`;
        }

function renderThreads(){
  if(customerFilter){
    // When opened from Customers page, we hide the list anyway.
    return;
  }

  const q = (txtSearch?.value ?? '').trim().toLowerCase();
  const onlyUnread = chkUnread?.checked === true;
  const sortMode = selSort?.value ?? 'latest';

  let list = Array.isArray(allThreads) ? [...allThreads] : [];

  if(q){
    list = list.filter(t =>
      (t.customerName ?? '').toLowerCase().includes(q) ||
      (t.customerPhone ?? '').toLowerCase().includes(q) ||
      (t.lastMessagePreview ?? '').toLowerCase().includes(q) ||
      String(t.customerId ?? '').includes(q) ||
      String(t.id ?? '').includes(q)
    );
  }

  if(onlyUnread){
    list = list.filter(t => (t.unreadCount ?? 0) > 0);
  }

  // Sort
  if(sortMode === 'unread'){
    list.sort((a,b)=>{
      const au = (a.unreadCount ?? 0) > 0 ? 1 : 0;
      const bu = (b.unreadCount ?? 0) > 0 ? 1 : 0;
      if(au !== bu) return bu - au;
      const at = new Date(a.lastMessageAtUtc ?? a.updatedAtUtc ?? a.createdAtUtc ?? 0).getTime();
      const bt = new Date(b.lastMessageAtUtc ?? b.updatedAtUtc ?? b.createdAtUtc ?? 0).getTime();
      return bt - at;
    });
  } else {
    list.sort((a,b)=>{
      const at = new Date(a.lastMessageAtUtc ?? a.updatedAtUtc ?? a.createdAtUtc ?? 0).getTime();
      const bt = new Date(b.lastMessageAtUtc ?? b.updatedAtUtc ?? b.createdAtUtc ?? 0).getTime();
      return bt - at;
    });
  }

  if(!list.length){
    threadsDiv.innerHTML = '<div class="text-muted small">لا يوجد محادثات</div>';
    return;
  }

  threadsDiv.innerHTML = `
    <div class="list-group">
      ${list.map(t=>{
        const isActive = (t.id === currentThreadId);
        const unread = (t.unreadCount ?? 0);
        const blocked = t.isChatBlocked === true;
        const title = _escapeHtml((t.customerName && t.customerName.trim()) ? t.customerName : ('زبون #' + t.customerId));
        const phone = _escapeHtml(t.customerPhone ?? '');
        const preview = _escapeHtml(t.lastMessagePreview ?? '');
        const time = _fmtTime(t.lastMessageAtUtc ?? t.updatedAtUtc ?? t.createdAtUtc);

        return `
          <button type="button" class="list-group-item list-group-item-action ${isActive?'active':''}"
                  onclick="openThread(${t.id}, ${t.customerId}, ${blocked ? 'true':'false'})">
            <div class="d-flex justify-content-between align-items-start">
              <div class="me-2" style="min-width:0">
                <div class="fw-semibold text-truncate">${title}
                  ${blocked ? '<span class="badge text-bg-warning ms-2">موقوف</span>' : ''}
                </div>
                <div class="small opacity-75 text-truncate">${phone ? phone + ' • ' : ''}#${t.id}${t.orderId ? (' • طلب #' + t.orderId) : ''}</div>
                <div class="small text-truncate">${preview || '<span class="opacity-75">—</span>'}</div>
              </div>
              <div class="text-end" style="white-space:nowrap;">
                <div class="small opacity-75">${time}</div>
                ${unread>0 ? `<span class="badge text-bg-danger">${unread}</span>` : ''}
              </div>
            </div>
          </button>`;
      }).join('')}
    </div>`;
}

function fmtMsg(m){
  const isAuto = m.isAutoReply === true || (typeof m.message === 'string' && m.message.startsWith('🤖'));
  const cls = m.fromAdmin ? 'text-end' : 'text-start';
  let bg, senderLabel;
  if (!m.fromAdmin) {
    bg = 'bg-light border';
    senderLabel = 'الزبون';
  } else if (isAuto) {
    bg = 'bg-success bg-opacity-10 border border-success border-opacity-25';
    senderLabel = '<span class="badge bg-success bg-opacity-75 me-1" style="font-size:10px">🤖 رد تلقائي</span>الإدارة';
  } else {
    bg = 'bg-primary text-white';
    senderLabel = '✍️ الإدارة';
  }
  const safeText = (m.message||'').replace(/"/g,'&quot;');
  return `<div class="${cls} mb-2 ai-msg-item" data-from-admin="${m.fromAdmin?'true':'false'}" data-text="${safeText}">
    <div class="d-inline-block px-3 py-2 rounded-4 ${bg}" style="max-width:85%;text-align:start">${_escapeHtml(m.message||'')}</div>
    <div class="small text-muted mt-1">${senderLabel} • ${_fmtTime(m.createdAtUtc||m.CreatedAtUtc)}</div>
  </div>`;
}

async function loadThreads(){
  // If opened from Customers list: ensure a chat thread exists, open it, and hide the threads list.
  if(customerFilter){
    document.getElementById('threadsCol').classList.add('d-none');
    const r = await fetch(`/api/admin/chat-thread/${customerFilter}`);
    if(!r.ok){ threadsDiv.innerText='فشل التحميل'; return; }
    const info = await r.json();
    currentCustomerId = info.customerId;
    isChatBlocked = info.isChatBlocked === true;
    _renderBlockState();
    await openThread(info.threadId, info.customerId, info.isChatBlocked === true);
    return;
  }
  const res = await fetch('/api/admin/complaints');
  if(!res.ok){ threadsDiv.innerText='فشل التحميل'; return; }
  allThreads = await res.json();
  renderThreads();
}

function _renderBlockState(){
  btnToggleBlock.classList.remove('d-none');
  document.getElementById('btnArchive').classList.remove('d-none');
  if(isChatBlocked){
    badgeBlocked.classList.remove('d-none');
    btnToggleBlock.textContent = 'إلغاء الإيقاف';
    btnToggleBlock.classList.remove('btn-outline-danger');
    btnToggleBlock.classList.add('btn-outline-success');
    document.getElementById('replyText').disabled = false; // admin can still reply
    document.getElementById('btnSend').disabled = false;
  } else {
    badgeBlocked.classList.add('d-none');
    btnToggleBlock.textContent = 'إيقاف';
    btnToggleBlock.classList.remove('btn-outline-success');
    btnToggleBlock.classList.add('btn-outline-danger');
    document.getElementById('replyText').disabled = false;
    document.getElementById('btnSend').disabled = false;
  }
}

window.openThread = async(id, customerId, blocked)=>{
  currentThreadId = id;
  if(customerId){
    currentCustomerId = customerId;
    isChatBlocked = blocked === true;
    _renderBlockState();
  }
  window._msgKeys = window._msgKeys || new Set();
  const res = await fetch('/api/admin/complaint/'+id);
  if(!res.ok){ messagesDiv.innerText='فشل تحميل المحادثة'; return; }
  const t = await res.json();

  currentCustomerId = t.customerId;
  isChatBlocked = t.isChatBlocked === true;
  _renderBlockState();

  // Load customer details card
  try{
    const det = await fetch(`/api/admin/customers/${t.customerId}/details`);
    if(det.ok){ renderCustomerInfo(await det.json()); }
    else { customerInfoDiv.innerHTML = ''; }
  } catch { customerInfoDiv.innerHTML = ''; }

  // Build initial list + de-dup keys, then we can append new messages in realtime.
  window._msgKeys = new Set();
  messagesDiv.innerHTML = (t.messages||[]).map(m=>{
    const mid = (m.id||m.Id||0);
    window._msgKeys.add(mid ? ('id:'+mid) : (`${m.createdAtUtc}|${m.fromAdmin?'A':'C'}|${m.message}`));
    return fmtMsg(m);
  }).join('');
  messagesDiv.scrollTop = messagesDiv.scrollHeight;

  // Mark unread as 0 in list (we just opened it)
  const idx = allThreads.findIndex(x => x.id === id);
  if(idx >= 0){
    allThreads[idx].unreadCount = 0;
    allThreads[idx].customerId = t.customerId;
    allThreads[idx].customerName = t.customerName;
    allThreads[idx].customerPhone = t.customerPhone;
    allThreads[idx].isChatBlocked = t.isChatBlocked;
    renderThreads();
  }
}

function _appendMsg(m){
  // Use DB id for de-dup (reconnect / optimistic UI issues)
  const id = (m.id||m.Id||0);
  const k = id ? ('id:'+id) : ((m.createdAtUtc||'')+'|'+(m.fromAdmin?1:0)+'|'+(m.message||''));
  if(window._msgKeys.has(k)) return;
  window._msgKeys.add(k);
  messagesDiv.insertAdjacentHTML('beforeend', fmtMsg(m));
  messagesDiv.scrollTop = messagesDiv.scrollHeight;
}

btnToggleBlock.addEventListener('click', async()=>{
  if(!currentCustomerId){ alert('اختر زبون'); return; }
  const target = !isChatBlocked;
  const res = await fetch(`/api/admin/customers/${currentCustomerId}/chat-block`, {
    method:'POST',
    headers: { 'Content-Type':'application/json' },
    body: JSON.stringify({ blocked: target })
  });
  if(!res.ok){ alert('فشل'); return; }
  const j = await res.json();
  isChatBlocked = j.isChatBlocked === true;
  _renderBlockState();
});

document.getElementById('btnArchive').addEventListener('click', async()=>{
  if(!currentThreadId){ alert('اختر محادثة'); return; }
  if(!confirm('هل تريد إزالة هذه الشكوى من القائمة؟ ستبقى البيانات محفوظة.')) return;
  const res = await fetch(`/api/admin/complaint/${currentThreadId}/archive`, { method:'POST' });
  if(!res.ok){ alert('فشل'); return; }
  // remove from local list and reset UI
  allThreads = allThreads.filter(x => x.id !== currentThreadId);
  currentThreadId = null;
  currentCustomerId = null;
  messagesDiv.innerHTML = '';
  customerInfoDiv.innerHTML = '';
  document.getElementById('btnArchive').classList.add('d-none');
  btnToggleBlock.classList.add('d-none');
  renderThreads();
  status.textContent = '✅ تمت إزالة الشكوى من القائمة';
});

document.getElementById('btnSend').addEventListener('click', async()=>{
  if(!currentThreadId) { alert('اختر محادثة'); return; }
  if(isChatBlocked){ alert('الدردشة موقوفة لهذا الزبون'); return; }
  const txtEl = document.getElementById('replyText');
  const txt = txtEl.value.trim();
  if(!txt) return;

  const btn = document.getElementById('btnSend');
  btn.disabled = true;
  status.innerText='جاري الإرسال...';
  try{
    const res = await fetch(`/api/admin/complaint/${currentThreadId}/reply`, {
      method:'POST',
      headers: { 'Content-Type':'application/json' },
      body: JSON.stringify({ message: txt })
    });
    if(!res.ok){
      status.innerText = 'فشل الإرسال ❌';
      return;
    }
    await res.json();
    // IMPORTANT: Do NOT optimistically append here.
    // The server broadcasts the message via SignalR (chat_message_received).
    // Optimistic append can cause duplicate messages in real-world reconnect / multi-connection scenarios.
    txtEl.value='';
    status.innerText = 'تم إرسال الرد وإشعار الزبون ✅';
  } finally {
    btn.disabled = false;
  }
});

document.getElementById('btnRefresh').addEventListener('click', loadThreads);

// Live updates
const hub = new signalR.HubConnectionBuilder().withUrl('/hubs/notify').withAutomaticReconnect().build();
hub.start().catch(console.error);
hub.on('complaint_new', ()=>loadThreads());
hub.off('chat_message_received');
hub.on('chat_message_received', (p)=>{
  if(p && p.broadcast){ loadThreads(); return; }
  if(p.threadId===currentThreadId){
    _appendMsg(p);
    // Update preview + time for current thread
    const idx = allThreads.findIndex(x => x.id === p.threadId);
    if(idx>=0){
      allThreads[idx].lastMessageAtUtc = p.createdAtUtc;
      const prefix = p.fromAdmin ? 'الإدارة: ' : 'الزبون: ';
      const msg = (p.message ?? '');
      allThreads[idx].lastMessagePreview = prefix + (msg.length>60 ? msg.substring(0,60)+'…' : msg);
      allThreads[idx].unreadCount = 0;
      renderThreads();
    }
  }
  else {
    // Update list for other threads
    const idx = allThreads.findIndex(x => x.id === p.threadId);
    if(idx>=0){
      allThreads[idx].lastMessageAtUtc = p.createdAtUtc;
      const prefix = p.fromAdmin ? 'الإدارة: ' : 'الزبون: ';
      const msg = (p.message ?? '');
      allThreads[idx].lastMessagePreview = prefix + (msg.length>60 ? msg.substring(0,60)+'…' : msg);
      // Only increment unread if it's from customer
      if(!p.fromAdmin){
        allThreads[idx].unreadCount = (allThreads[idx].unreadCount ?? 0) + 1;
      }
      renderThreads();
    } else {
      // Fallback: reload if thread not found
      loadThreads();
    }
  }
});

hub.on('chat_blocked', (p)=>{
  if(currentCustomerId && p.customerId===currentCustomerId){
    isChatBlocked = p.isChatBlocked === true;
    _renderBlockState();
  }
});

// ===== AI اقتراح رد =====
document.getElementById('btnAiSuggest').addEventListener('click', async () => {
  if (!currentThreadId) { alert('اختر محادثة أولاً'); return; }
  const btn = document.getElementById('btnAiSuggest');
  const spinner = document.getElementById('aiSuggestSpinner');
  const btnText = btn.querySelector('.btn-text');
  btn.disabled = true;
  spinner.classList.remove('d-none');
  btnText.textContent = 'جاري التحليل...';
  try {
    // جمع آخر 10 رسائل من المحادثة
    const msgEls = document.querySelectorAll('#messages .ai-msg-item');
    const msgs = [];
    msgEls.forEach(el => {
      const fromAdmin = el.dataset.fromAdmin === 'true';
      const text = el.dataset.text || '';
      if (text) msgs.push({ role: fromAdmin ? 'admin' : 'customer', text });
    });
    const lastMsgs = msgs.slice(-10);

    // جلب معلومات الزبون إن وجدت
    const custName = document.querySelector('#customerInfo .fw-semibold')?.textContent?.trim() || 'الزبون';

    const payload = {
      max_tokens: 1000,
      system: `أنت مساعد خدمة عملاء محترف يعمل لدى متجرنا.
مهمتك كتابة رد احترافي بالعربي على رسالة الزبون ${custName}.
قواعد: ابدأ بتحية، أظهر تعاطفاً، قدّم حلاً، اختم إيجابياً. 2-4 جمل — بدون مقدمة.`,
      max_tokens: 600,
      messages: [
        {
          role: 'user',
          content: `اسم الزبون: ${custName}\n\nسجل المحادثة:\n${lastMsgs.map(m=>`${m.role==='customer'?'الزبون':'الإدارة'}: ${m.text}`).join('\n')}\n\naكتب ردًا مناسبًا على آخر رسالة للزبون.`
        }
      ]
    };

    const res = await fetch('/api/ai/chat', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload)

    });
    if (!res.ok) {
      const errData = await res.json().catch(() => ({}));
      alert('⚠️ ' + (errData.error || 'حدث خطأ في الاتصال بـ AI'));
      return;
    }
    const data = await res.json();
    const text = (data.content || []).map(b => b.text || '').join('').trim();
    if (text) {
      document.getElementById('replyText').value = text;
      document.getElementById('status').textContent = '✅ تم اقتراح رد بواسطة AI — راجعه وأرسله';
    } else {
      alert('لم يتمكن AI من اقتراح رد حاليًا');
    }
  } catch (e) {
    alert('خطأ في الاتصال بـ AI: ' + e.message);
  } finally {
    btn.disabled = false;
    spinner.classList.add('d-none');
    btnText.textContent = 'اقتراح رد AI';
  }
});

loadThreads();

txtSearch?.addEventListener('input', ()=>renderThreads());
chkUnread?.addEventListener('change', ()=>renderThreads());
selSort?.addEventListener('change', ()=>renderThreads());

// ===== تحميل حالة الرد التلقائي من الخادم =====
async function loadAutoReplyState() {
  try {
    const res = await fetch('/api/admin/settings');
    if (!res.ok) return;
    const s = await res.json();
    const enabled = s.aiAutoReplyEnabled !== false;
    document.getElementById('chkAutoReply').checked = enabled;
    updateAutoReplyLabel(enabled);
  } catch {}
}

function updateAutoReplyLabel(enabled) {
  const lbl = document.getElementById('autoReplyLabel');
  if (lbl) lbl.textContent = enabled ? '🤖 رد تلقائي: مفعّل' : '🤖 رد تلقائي: معطّل';
}

document.getElementById('chkAutoReply').addEventListener('change', async (e) => {
  const enabled = e.target.checked;
  updateAutoReplyLabel(enabled);
  try {
    const res = await fetch('/api/admin/settings', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ aiAutoReplyEnabled: enabled })
    });
    if (res.ok) {
      status.textContent = enabled ? '✅ تم تفعيل الرد التلقائي بالذكاء الاصطناعي' : '⏸️ تم تعطيل الرد التلقائي';
    } else {
      status.textContent = '❌ فشل حفظ الإعداد';
      e.target.checked = !enabled;
      updateAutoReplyLabel(!enabled);
    }
  } catch {
    e.target.checked = !enabled;
    updateAutoReplyLabel(!enabled);
  }
});

loadAutoReplyState();
</script>
}
