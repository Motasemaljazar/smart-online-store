@page
@model AdminDashboard.Pages.Admin.AdminPageModel

<h2 class="h5 mb-4">إعدادات النظام</h2>

<form id="frm" class="card shadow-sm p-4 rounded-3" onsubmit="return false;">
    <div class="row g-3">

        <div class="col-md-6">
            <label class="form-label fw-semibold">اسم المتجر</label>
            <input class="form-control" name="storeName" placeholder="أدخل اسم المتجر" />
        </div>

        <div class="col-md-6">
            <label class="form-label fw-semibold">شعار المتجر</label>
            <input class="form-control" type="file" id="logoFile" accept="image/*" />
            <div class="mt-2" id="logoPreview"></div>
        </div>

        <div class="col-md-4">
            <label class="form-label fw-semibold">حالة المتجر</label>
            <select class="form-select" name="isManuallyClosed">
                <option value="false">مفتوح</option>
                <option value="true">مغلق</option>
            </select>
        </div>

        <div class="col-md-6">
            <label class="form-label fw-semibold">رسالة الإغلاق</label>
            <input class="form-control" name="closedMessage" placeholder="المتجر مغلق حالياً" />
        </div>

        <div class="col-md-6">
            <label class="form-label">خلفية شاشة الإغلاق</label>
            <input class="form-control" type="file" id="closedBgFile" accept="image/*" />
            <div class="mt-2 small" id="closedBgPreview"></div>
        </div>

        <div class="col-12">
            <hr class="my-2" />
            <h3 class="h6 mb-2"></h3>
            <div class="row g-2 align-items-end">
                <div class="col-md-6">
                    <label class="form-label">إضافة صور بنرات</label>
                    <input class="form-control" type="file" id="bannerFiles" accept="image/*" multiple />
                    <div class="form-text"></div>
                </div>
                <div class="col-md-3">
                    <button class="btn btn-outline-primary w-100" type="button" id="btnAddBanners">رفع وإضافة</button>
                </div>
                <div class="col-md-3">
                    <button class="btn btn-outline-danger w-100" type="button" id="btnClearBanners">حذف الكل</button>
                </div>
            </div>

            <div class="mt-3" id="bannersList"></div>
            <input type="hidden" name="homeBannersJson" />
        </div>

        <div class="col-md-6">
            <label class="form-label">رقم الدعم</label>
            <input class="form-control" name="supportPhone" placeholder="" />
        </div>

        <div class="col-md-6">
            <label class="form-label">واتساب الدعم</label>
            <input class="form-control" name="supportWhatsApp" placeholder="" />
        </div>

        <div class="col-12">
            <hr class="my-2" />
            <h3 class="h6 mb-2">روابط وسائل التواصل الاجتماعي</h3>
        </div>

        <div class="col-md-4">
            <label class="form-label">رابط Instagram</label>
            <input class="form-control" name="instagramUrl" placeholder="https://instagram.com/..." />
        </div>

        <div class="col-md-4">
            <label class="form-label">رابط Facebook</label>
            <input class="form-control" name="facebookUrl" placeholder="https://facebook.com/..." />
        </div>

        <div class="col-md-4">
            <label class="form-label">رابط Telegram</label>
            <input class="form-control" name="telegramUrl" placeholder="https://t.me/..." />
        </div>

        <div class="col-12">
            <hr class="my-2" />
            <h3 class="h6 mb-2">موقع المتجر</h3>
            <div class="d-flex gap-2 flex-wrap mb-2">
                <button class="btn btn-outline-primary btn-sm" type="button" id="btnOpenMap">تحديد من الخريطة</button>
                <button class="btn btn-outline-secondary btn-sm" type="button" id="btnGetLoc">تحديد تلقائي (موقعي الآن)</button>
            </div>
            <input type="hidden" name="storeLat" />
            <input type="hidden" name="storeLng" />
            <div id="mapSection" class="mt-2 d-none">
                <div class="position-relative rounded-4 overflow-hidden border" style="height:340px">
                    <div id="mapStore" style="height:340px"></div>
                    <!-- Professional Pulsing Circle Marker - Always Visible and Always Active -->
                    <div id="pulseMarker" style="position:absolute;left:50%;top:50%;transform:translate(-50%,-50%);pointer-events:none;z-index:1000;display:none;">
                        <!-- Outer Pulsing Circle -->
                        <div class="pulse-circle outer" style="width:100px;height:100px;border-radius:50%;background:rgba(0,120,255,0.1);border:4px solid rgba(0,120,255,0.5);position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);"></div>
                        <!-- Middle Pulsing Circle -->
                        <div class="pulse-circle middle" style="width:70px;height:70px;border-radius:50%;background:rgba(0,120,255,0.2);border:3px solid rgba(0,120,255,0.7);position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);"></div>
                        <!-- Inner Pulsing Circle -->
                        <div class="pulse-circle inner" style="width:50px;height:50px;border-radius:50%;background:rgba(0,120,255,0.3);border:2px solid rgba(0,120,255,0.9);position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);"></div>
                        <!-- Center Pin -->
                        <div class="center-pin" style="width:20px;height:20px;border-radius:50%;background:linear-gradient(135deg, #0078ff, #0055cc);border:4px solid white;box-shadow:0 0 20px rgba(0,120,255,0.9), 0 0 0 6px rgba(0,120,255,0.3);position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);z-index:10;"></div>
                        <!-- Pin Glow -->
                        <div style="width:40px;height:40px;border-radius:50%;background:radial-gradient(circle, rgba(0,120,255,0.5) 0%, rgba(0,120,255,0) 80%);position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);z-index:5;"></div>
                        <!-- Location Text -->
                        <div style="position:absolute;top:calc(50% + 70px);left:50%;transform:translateX(-50%);background:rgba(0,0,0,0.7);color:white;padding:4px 12px;border-radius:20px;font-size:12px;white-space:nowrap;backdrop-filter:blur(5px);">
                            موقع المتجر الحالي
                        </div>
                    </div>
                </div>
                <div class="mt-2 text-end">
                    <button class="btn btn-sm btn-outline-secondary" type="button" id="btnCloseMap">إخفاء الخريطة</button>
                </div>
            </div>
        </div>

        <div class="col-12">
            <button class="btn btn-primary" id="btnSave" type="button">حفظ</button>
            <span class="me-2 small text-muted" id="status"></span>
        </div>
    </div>
</form>

@section Scripts {
    <script>
        const frm = document.getElementById('frm');
        const status = document.getElementById('status');

        let current = {
          storeName: '',
          logoUrl: null,
          isManuallyClosed: false,
          closedMessage: 'المتجر مغلق حالياً',
          closedScreenImageUrl: null,
          homeBanners: [],
          deliveryFeePerKm: 0,
          deliveryFeeValue: 0,
          deliveryFeeType: 0,
          supportPhone: '',
          supportWhatsApp: '',
          instagramUrl: '',
          facebookUrl: '',
          telegramUrl: '',
          storeLat: 0,
          storeLng: 0,
          routingProfile: 'driving'
        };

        let map;
        let mapReady = false;
        let pulseMarker;
        let currentLat = 0;
        let currentLng = 0;
        let markerShown = false;
        const mapSection = document.getElementById('mapSection');

        function fmt(n){
          if(typeof n !== 'number' || !isFinite(n)) return '—';
          return n.toFixed(6);
        }

        function setLatLng(lat, lng){
          current.storeLat = lat;
          current.storeLng = lng;
          frm.storeLat.value = String(lat);
          frm.storeLng.value = String(lng);
          // Update global coordinates
          currentLat = lat;
          currentLng = lng;
        }

        function ensureMap(){
          if(mapReady) return;
          mapReady = true;
          map = L.map('mapStore', { zoomControl: true, attributionControl: false });
          L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { maxZoom: 19 }).addTo(map);

          // Get pulse marker element
          pulseMarker = document.getElementById('pulseMarker');

          // Update marker position when map moves
          map.on('move', ()=>{
            const c = map.getCenter();
            setLatLng(c.lat, c.lng);
            if (markerShown) {
              updateMarkerPosition();
            }
          });
        }

        async function uploadAsset(kind, file){
          if(!file) return null;

          // التحقق من حجم الملف فقط (حد 20MB للصورة الواحدة)
          if(file.size > 20 * 1024 * 1024){
            throw new Error(`الملف كبير جداً: ${(file.size/1024/1024).toFixed(1)}MB (الحد الأقصى 20MB)`);
          }

          const fd = new FormData();
          fd.append('file', file);
          const res = await fetch(`/api/admin/upload/asset?kind=${encodeURIComponent(kind)}`, {
            method:'POST',
            body: fd,
            credentials: 'same-origin'
          });
          if(!res.ok){
            let errMsg = `خطأ ${res.status}`;
            try{
              const j = await res.json();
              errMsg = j.message || j.error || errMsg;
            }catch(_){}
            throw new Error(errMsg);
          }
          const j = await res.json();
          return j.url;
        }

        function setPreview(elId, url){
          const el = document.getElementById(elId);
          if(!el) return;
          const u = url ? (url + (url.includes('?') ? '&' : '?') + 'v=' + Date.now()) : null;
          el.innerHTML = u ? `<a href="${u}" target="_blank">عرض</a> | <img src="${u}" style="height:44px;border-radius:10px;object-fit:cover;margin-inline-start:8px" />` : '<span class="text-muted">—</span>';
        }

        function setBannersJson(){
          frm.homeBannersJson.value = JSON.stringify(current.homeBanners || []);
        }

        document.getElementById('btnOpenMap').addEventListener('click', ()=>{
          mapSection.classList.remove('d-none');
          ensureMap();
          // عند الفتح، ركّز الخريطة على إحداثيات المتجر الحالية إن وُجدت
          const lat = (current.storeLat && Math.abs(current.storeLat) > 0.000001) ? current.storeLat : 33.5138;
          const lng = (current.storeLng && Math.abs(current.storeLng) > 0.000001) ? current.storeLng : 36.2765;
          map.setView([lat, lng], (current.storeLat && current.storeLng) ? 16 : 13);
        });

        document.getElementById('btnCloseMap').addEventListener('click', ()=>{
          mapSection.classList.add('d-none');
        });

        function renderBanners(){
          const host = document.getElementById('bannersList');
          if(!host) return;
          // تأكد أن كل عنصر string وليس object
          const raw = current.homeBanners || [];
          const list = raw.map(u => (typeof u === 'string') ? u : (u && u.url ? u.url : String(u))).filter(u => u && u.length > 0);
          current.homeBanners = list;
          setBannersJson();
          if(list.length===0){
            host.innerHTML = '<div class="text-muted small">لا توجد بنرات. ارفع صور لإظهار سلايدر أعلى تطبيق الزبون.</div>';
            return;
          }
          host.innerHTML = `
            <div class="d-flex flex-column gap-2">
              ${list.map((u,i)=>`
                <div class="d-flex align-items-center gap-2 border rounded-4 p-2">
                  <img src="${u}${u.includes('?')?'&':'?'}v=${Date.now()}" style="height:54px;width:120px;object-fit:cover;border-radius:12px" />
                  <div class="flex-grow-1 small text-muted" style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${u}</div>
                  <div class="btn-group btn-group-sm" role="group">
                    <button class="btn btn-outline-secondary" type="button" data-act="up" data-i="${i}">↑</button>
                    <button class="btn btn-outline-secondary" type="button" data-act="down" data-i="${i}">↓</button>
                    <button class="btn btn-outline-danger" type="button" data-act="del" data-i="${i}">حذف</button>
                  </div>
                </div>
              `).join('')}
            </div>
          `;

          host.querySelectorAll('button[data-act]').forEach(b=>{
            b.addEventListener('click', ()=>{
              const act = b.getAttribute('data-act');
              const i = parseInt(b.getAttribute('data-i')||'0',10);
              const arr = [...(current.homeBanners||[])];
              if(act==='del'){
                arr.splice(i,1);
              }else if(act==='up' && i>0){
                const tmp = arr[i-1]; arr[i-1]=arr[i]; arr[i]=tmp;
              }else if(act==='down' && i<arr.length-1){
                const tmp = arr[i+1]; arr[i+1]=arr[i]; arr[i]=tmp;
              }
              current.homeBanners = arr;
              renderBanners();
            });
          });
        }

        // Function to show the professional pulsing circle PERMANENTLY
        function showPulseMarker() {
          if (!pulseMarker) {
            pulseMarker = document.getElementById('pulseMarker');
            if (!pulseMarker) return;
          }

          // Show the pulse marker
          pulseMarker.style.display = 'block';
          markerShown = true;

          // Start the animations
          startPulseAnimations();
        }

        // Function to update marker position (keep it centered)
        function updateMarkerPosition() {
          if (!pulseMarker || !markerShown) return;
          // Marker is already centered with CSS transform
          // No need to update position as it's always at center
        }

        // Function to start pulse animations
        function startPulseAnimations() {
          if (!pulseMarker) return;

          // Add animation classes to pulse circles
          const outerCircle = pulseMarker.querySelector('.pulse-circle.outer');
          const middleCircle = pulseMarker.querySelector('.pulse-circle.middle');
          const innerCircle = pulseMarker.querySelector('.pulse-circle.inner');
          const centerPin = pulseMarker.querySelector('.center-pin');

          if (outerCircle) {
            outerCircle.style.animation = 'pulse-outer 2s infinite';
          }
          if (middleCircle) {
            middleCircle.style.animation = 'pulse-middle 1.5s infinite 0.3s';
          }
          if (innerCircle) {
            innerCircle.style.animation = 'pulse-inner 1s infinite 0.6s';
          }
          if (centerPin) {
            centerPin.style.animation = 'pin-pulse 2s infinite';
          }
        }

        // Banners actions
        document.getElementById('btnClearBanners').addEventListener('click', ()=>{
          current.homeBanners = [];
          renderBanners();
          status.innerText = 'تم حذف البنرات (لم يتم الحفظ بعد)';
        });

        document.getElementById('btnAddBanners').addEventListener('click', async ()=>{
          const input = document.getElementById('bannerFiles');
          const files = Array.from(input.files || []);
          if(files.length===0){ status.innerText = 'اختر صوراً أولاً'; return; }

          const btn = document.getElementById('btnAddBanners');
          btn.disabled = true;

          let successCount = 0;
          let failedFiles = [];

          status.innerText = `جارٍ رفع ${files.length} صورة...`;

          for(let i = 0; i < files.length; i++){
            const f = files[i];
            status.innerText = `جارٍ رفع الصورة ${i+1} من ${files.length}: ${f.name}`;
            try{
              const url = await uploadAsset('banner', f);
              if(url){
                current.homeBanners = [...(current.homeBanners||[]), url];
                successCount++;
              }
            }catch(err){
              failedFiles.push(f.name);
              console.error('فشل رفع:', f.name, err);
            }
          }

          btn.disabled = false;
          input.value = '';
          renderBanners();

          if(failedFiles.length === 0){
            status.innerText = `تم رفع ${successCount} صورة بنجاح ✅ (اضغط حفظ لتطبيقها)`;
          } else if(successCount > 0){
            status.innerText = `تم رفع ${successCount} صورة ✅، وفشل رفع ${failedFiles.length} صورة: ${failedFiles.join('، ')}`;
          } else {
            status.innerText = `فشل رفع جميع الصور (${failedFiles.join('، ')}) — تحقق من نوع وحجم الملفات`;
          }
        });

        async function load(){
          const res = await fetch('/api/admin/settings', { credentials: 'same-origin' });
          if(!res.ok){ status.innerText='فشل تحميل الإعدادات'; return; }
          const s = await res.json();

          current.storeName = s.storeName || '';
          current.logoUrl = s.logoUrl || null;
          current.isManuallyClosed = !!s.isManuallyClosed;
          current.closedMessage = s.closedMessage || 'المتجر مغلق حالياً';
          current.closedScreenImageUrl = s.closedScreenImageUrl || null;
          // Home banners (JSON array of URLs)
          try{
            const bj = s.homeBannersJson || s.homeBanners || null;
            if(Array.isArray(bj)) current.homeBanners = bj;
            else if(typeof bj === 'string' && bj.trim().length){
              const parsed = JSON.parse(bj);
              current.homeBanners = Array.isArray(parsed) ? parsed : [];
            }else{
              current.homeBanners = [];
            }
          }catch(_){ current.homeBanners = []; }
          current.deliveryFeePerKm = (typeof s.deliveryFeePerKm === 'number') ? s.deliveryFeePerKm : (parseFloat(s.deliveryFeePerKm) || 0);
          current.deliveryFeeValue = (typeof s.deliveryFeeValue === 'number') ? s.deliveryFeeValue : (parseFloat(s.deliveryFeeValue) || 0);
          current.deliveryFeeType  = (typeof s.deliveryFeeType === 'number') ? s.deliveryFeeType : (parseInt(s.deliveryFeeType) || 0);
          current.supportPhone = s.supportPhone || '';
          current.supportWhatsApp = s.supportWhatsApp || '';
          current.instagramUrl = s.instagramUrl || '';
          current.facebookUrl = s.facebookUrl || '';
          current.telegramUrl = s.telegramUrl || '';
          current.storeLat = (typeof s.storeLat === 'number') ? s.storeLat : 0;
          current.storeLng = (typeof s.storeLng === 'number') ? s.storeLng : 0;

          frm.storeName.value = current.storeName;
          frm.isManuallyClosed.value = current.isManuallyClosed ? 'true' : 'false';
          frm.closedMessage.value = current.closedMessage;
          if (frm.deliveryFeePerKm) frm.deliveryFeePerKm.value = current.deliveryFeePerKm > 0 ? String(current.deliveryFeePerKm) : '';
          if (frm.deliveryFeeValue) frm.deliveryFeeValue.value = current.deliveryFeeValue > 0 ? String(current.deliveryFeeValue) : '';
          if (frm.deliveryFeeType) frm.deliveryFeeType.value = String(current.deliveryFeeType || 0);
          frm.supportPhone.value = current.supportPhone;
          frm.supportWhatsApp.value = current.supportWhatsApp;
          frm.instagramUrl.value = current.instagramUrl;
          frm.facebookUrl.value = current.facebookUrl;
          frm.telegramUrl.value = current.telegramUrl;
          frm.storeLat.value = String(current.storeLat || 0);
          frm.storeLng.value = String(current.storeLng || 0);

          setPreview('logoPreview', current.logoUrl);
          setPreview('closedBgPreview', current.closedScreenImageUrl);
          renderBanners();

          ensureMap();
          const lat = (current.storeLat && Math.abs(current.storeLat) > 0.000001) ? current.storeLat : 33.5138;
          const lng = (current.storeLng && Math.abs(current.storeLng) > 0.000001) ? current.storeLng : 36.2765;
          map.setView([lat, lng], (current.storeLat && current.storeLng) ? 16 : 13);
          setLatLng(map.getCenter().lat, map.getCenter().lng);

          // Show pulse marker immediately if we have valid coordinates
          if (current.storeLat && current.storeLng &&
              Math.abs(current.storeLat) > 0.000001 &&
              Math.abs(current.storeLng) > 0.000001) {
            setTimeout(() => {
              showPulseMarker();
            }, 500);
          }
        }

        document.getElementById('btnGetLoc').addEventListener('click', ()=>{
          ensureMap();
          if(!navigator.geolocation){ status.innerText = 'المتصفح لا يدعم تحديد الموقع'; return; }
          status.innerText = 'جارٍ تحديد الموقع...';
          navigator.geolocation.getCurrentPosition(
            (pos)=>{
              const lat = pos.coords.latitude;
              const lng = pos.coords.longitude;
              map.setView([lat, lng], 17);
              setLatLng(lat, lng);
              status.innerText = 'تم تحديد الموقع ✅ ';

              // Show professional pulsing circle PERMANENTLY
              showPulseMarker();
            },
            (error)=>{
              if (error.code === error.PERMISSION_DENIED) {
                status.innerText = 'تم رفض الإذن. يرجى السماح بتحديد الموقع في إعدادات المتصفح.';
              } else if (error.code === error.POSITION_UNAVAILABLE) {
                status.innerText = 'معلومات الموقع غير متاحة.';
              } else if (error.code === error.TIMEOUT) {
                status.innerText = 'انتهت مهلة طلب الموقع.';
              } else {
                status.innerText = 'فشل تحديد الموقع (تأكد من السماح)';
              }
            },
            { enableHighAccuracy: true, timeout: 15000, maximumAge: 0 }
          );
        });

        document.getElementById('btnSave').addEventListener('click', async (ev)=>{
          ev.preventDefault();
          const btn = document.getElementById('btnSave');
          btn.disabled = true;
          status.innerText = 'جارٍ الحفظ...';

          let logoUrl = current.logoUrl;
          let closedBgUrl = current.closedScreenImageUrl;

          const logoFile = document.getElementById('logoFile').files?.[0];
          const bgFile = document.getElementById('closedBgFile').files?.[0];

          try{
            if(logoFile) logoUrl = await uploadAsset('logo', logoFile);
            if(bgFile) closedBgUrl = await uploadAsset('closed', bgFile);
          }catch(_){
            status.innerText = 'فشل رفع الصور';
            btn.disabled = false;
            return;
          }

          const isClosed = frm.isManuallyClosed.value === 'true';
          const deliveryFeePerKmVal = parseFloat((frm.deliveryFeePerKm && frm.deliveryFeePerKm.value) ? frm.deliveryFeePerKm.value : '0');
          const payload = {
            storeName: frm.storeName.value.trim(),
            logoUrl,
            isManuallyClosed: isClosed,
            isAcceptingOrders: !isClosed,
            closedMessage: frm.closedMessage.value.trim() || 'المتجر مغلق حالياً',
            closedScreenImageUrl: closedBgUrl,
            homeBannersJson: JSON.stringify(current.homeBanners || []),
            deliveryFeePerKm: isFinite(deliveryFeePerKmVal) && deliveryFeePerKmVal >= 0 ? deliveryFeePerKmVal : 0,
            deliveryFeeValue: isFinite(parseFloat(frm.deliveryFeeValue?.value || '0')) ? (parseFloat(frm.deliveryFeeValue?.value || '0') || 0) : 0,
            deliveryFeeType: parseInt(frm.deliveryFeeType?.value || '0') || 0,
            supportPhone: frm.supportPhone.value.trim(),
            supportWhatsApp: frm.supportWhatsApp.value.trim(),
            instagramUrl: frm.instagramUrl.value.trim(),
            facebookUrl: frm.facebookUrl.value.trim(),
            telegramUrl: frm.telegramUrl.value.trim(),
            storeLat: parseFloat(frm.storeLat.value || '0') || 0,
            storeLng: parseFloat(frm.storeLng.value || '0') || 0
          };

          const res = await fetch('/api/admin/settings', {
            method:'POST',
            headers:{'Content-Type':'application/json'},
            body: JSON.stringify(payload),
            credentials: 'same-origin'
          });

          const txt = await res.text();
          let data = {};
          try { data = txt ? JSON.parse(txt) : {}; } catch { data = { raw: txt }; }

          if(!res.ok){
            // Show more helpful info (and common auth hint)
            if(res.status === 401 || res.status === 403) status.innerText = 'فشل الحفظ: انتهت جلسة تسجيل الدخول. أعد تسجيل الدخول ثم جرّب.';
            else status.innerText = (data?.message ? data.message : 'فشل الحفظ') + (data?.error ? ` (${data.error})` : '');
            btn.disabled = false;
            return;
          }

          status.innerText = (data?.message ? data.message : 'تم الحفظ ✅');
          try { if (window.reloadBranding) await window.reloadBranding(); } catch(_) {}

          // Keep the pulse marker shown after saving
          if (markerShown) {
            status.innerText += '';
          }

          await load();
          btn.disabled = false;
        });

        document.addEventListener('DOMContentLoaded', load);
    </script>
}

