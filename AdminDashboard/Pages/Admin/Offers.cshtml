@page
@model AdminDashboard.Pages.Admin.AdminPageModel
@{
    ViewData["Title"] = "العروض";
}

<div class="d-flex align-items-center justify-content-between mb-4">
  <h3 class="m-0">إدارة العروض والخصومات</h3>
  <button class="btn btn-primary shadow-sm" onclick="ui.openNew()">
    <i class="bi bi-plus-circle me-1"></i> إضافة عرض جديد
  </button>
</div>

<div class="card shadow-sm">
  <div class="card-body">
    <div class="table-responsive admin-mobile-cards">
      <table class="table table-hover align-middle" id="tbl">
        <thead class="table-light">
          <tr>
            <th>#</th>
            <th>الصورة</th>
            <th>العنوان</th>
            <th>الفترة</th>
            <th class="text-center">الحالة</th>
            <th class="text-center">إجراءات</th>
          </tr>
        </thead>
        <tbody></tbody>
      </table>
    </div>
  </div>
</div>

<!-- Modal -->
<div class="modal fade" id="offerModal" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="offerModalTitle">عرض</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body" style="max-height:70vh; overflow:auto;">
        <div class="row g-3">

          <div class="col-md-8">
            <label class="form-label">العنوان</label>
            <input class="form-control" id="oTitle" />
          </div>

          <div class="col-md-4">
            <label class="form-label">الحالة</label>
            <div class="form-check mt-2">
              <input class="form-check-input" type="checkbox" id="oActive" checked>
              <label class="form-check-label" for="oActive">فعّال</label>
            </div>
          </div>

          <div class="col-md-6">
            <label class="form-label">بداية (UTC)</label>
            <input type="datetime-local" class="form-control" id="oStart" />
          </div>
          <div class="col-md-6">
            <label class="form-label">نهاية (UTC)</label>
            <input type="datetime-local" class="form-control" id="oEnd" />
          </div>

          <div class="col-12">
            <label class="form-label">وصف</label>
            <textarea class="form-control" id="oDesc" rows="3"></textarea>
          </div>

          <div class="col-md-4">
            <label class="form-label">السعر قبل الخصم</label>
            <input type="number" step="0.01" class="form-control" id="oPriceBefore" placeholder="اختياري" />
          </div>

          <div class="col-md-4">
            <label class="form-label">السعر بعد الخصم</label>
            <input type="number" step="0.01" class="form-control" id="oPriceAfter" placeholder="اختياري" />
          </div>

          <div class="col-md-4">
            <label class="form-label">كود (إن وجد)</label>
            <input class="form-control" id="oCode" placeholder="اختياري" />
          </div>

          <div class="col-12">
            <label class="form-label">صورة العرض</label>
            <input type="file" class="form-control" id="oImageFile" accept="image/*" />
            <div class="form-text">يتم رفع الصورة إلى السيرفر وتظهر في تطبيق الزبون.</div>
            <div class="mt-2" id="oImagePreview"></div>
          </div>

          <div class="col-12">
            <hr class="my-2" />
            <div class="fw-semibold mb-2">نطاق العرض (اختياري)</div>
            <div class="small text-muted">يمكن ربط العرض بأقسام أو منتجات محددة. إذا تركتها فارغة سيظهر العرض كبانر عام.</div>
          </div>

          <div class="col-md-6">
            <label class="form-label">الأقسام</label>
            <input class="form-control mb-2" id="catSearch" placeholder="بحث بالأقسام..." />
            <div class="border rounded-3 p-2" style="max-height:180px; overflow:auto" id="catList"></div>
            <div class="mt-2 small" id="catSelected"></div>
          </div>

          <div class="col-md-6">
            <label class="form-label">المنتجات</label>
            <input class="form-control mb-2" id="prodSearch" placeholder="بحث بالمنتجات..." />
            <div class="border rounded-3 p-2" style="max-height:180px; overflow:auto" id="prodList"></div>
            <div class="mt-2 small" id="prodSelected"></div>
          </div>

        </div>
      </div>
      <div class="modal-footer">
        <button class="btn btn-outline-secondary" data-bs-dismiss="modal">إلغاء</button>
  <button class="btn btn-primary" id="btnOfferSave" onclick="ui.save()">حفظ</button>
      </div>
    </div>
  </div>
</div>

@section Scripts {
<script>
  // Simple toast fallback (Bootstrap alert-style). Works even if global toast helper is missing.
  function toast(title, message){
    try{
      const el = document.createElement('div');
      el.className = 'alert alert-' + (title==='خطأ' ? 'danger' : 'success') + ' position-fixed bottom-0 start-0 m-3 shadow';
      el.style.zIndex = 9999;
      el.innerHTML = `<div class="fw-semibold mb-1">${escapeHtml(title)}</div><div>${escapeHtml(message)}</div>`;
      document.body.appendChild(el);
      setTimeout(()=>{ el.remove(); }, 2500);
    }catch(_){
      alert(`${title}: ${message}`);
    }
  }

  const ui = {
    items: [],
    menu: { categories: [], products: [] },
    selectedCategoryIds: [],
    selectedProductIds: [],
    editing: null,
    modal: null,
    saving: false,

    async loadMenu(){
      // Reuse menu endpoint to get categories/products for offer scope selection.
      const res = await fetch('/api/admin/menu');
      const data = await res.json().catch(()=>({}));
      this.menu.categories = (data.categories || []).filter(c=>c.isActive!==false);
      this.menu.products = (data.products || []).filter(p=>p.isActive!==false);
      renderScopeLists();
    },

    async load(){
      const res = await fetch('/api/admin/offers');
      const data = await res.json().catch(()=>({}));
      this.items = data.offers || [];
      const tbody = document.querySelector('#tbl tbody');
      tbody.innerHTML = '';
      for(const o of this.items){
        const tr = document.createElement('tr');
        const period = `${o.startsAtUtc? new Date(o.startsAtUtc).toLocaleString(): '-'} → ${o.endsAtUtc? new Date(o.endsAtUtc).toLocaleString(): '-'}`;
        const img = o.imageUrl ? `<img src="${o.imageUrl}" style="width:52px;height:40px;object-fit:cover;border-radius:8px" />` : '<span class="text-muted small">—</span>';
        tr.innerHTML = `
          <td data-label="#">${o.id}</td>
          <td data-label="الصورة">${img}</td>
          <td data-label="العنوان">${escapeHtml(o.title||'')}</td>
          <td class="small text-muted" data-label="الفترة">${period}</td>
          <td data-label="الحالة">${o.isActive? '<span class="badge bg-success">فعال</span>': '<span class="badge bg-secondary">موقف</span>'}</td>
          <td class="text-end mobile-actions-cell" data-label="">
            <button class="btn btn-sm btn-outline-primary" onclick="ui.edit(${o.id})">تعديل</button>
            <button class="btn btn-sm btn-outline-danger" onclick="ui.del(${o.id})">حذف</button>
          </td>`;
        tbody.appendChild(tr);
      }
    },

    openNew(){
      this.editing = null;
      this.selectedCategoryIds = [];
      this.selectedProductIds = [];
      fillOffer({title:'', description:'', imageUrl:null, startsAtUtc:null, endsAtUtc:null, isActive:true});
      this.modal.show();
    },

    edit(id){
      const o = this.items.find(x=>x.id===id);
      this.editing = o;
      this.selectedCategoryIds = Array.isArray(o.categoryIds) ? [...o.categoryIds] : [];
      this.selectedProductIds = Array.isArray(o.productIds) ? [...o.productIds] : [];
      fillOffer(o);
      this.modal.show();
    },

    async save(){
      if(this.saving) return;
      const title = document.getElementById('oTitle').value.trim();
      if(!title){ toast('خطأ','أدخل عنوان العرض'); return; }

      this.saving = true;
      const btn = document.getElementById('btnOfferSave');
      if(btn){ btn.disabled = true; btn.innerText = '...جارٍ الحفظ'; }

      let imageUrl = this.editing ? (this.editing.imageUrl || null) : null;
      const file = document.getElementById('oImageFile').files?.[0];
      if(file){
        try{
          imageUrl = await uploadAsset('offers', file);
        }catch(e){
          toast('خطأ','فشل رفع صورة العرض');
          this.saving = false;
          if(btn){ btn.disabled = false; btn.innerText = 'حفظ'; }
          return;
        }
      }

      const payload = {
        id: this.editing? this.editing.id : null,
        title,
        description: document.getElementById('oDesc').value.trim() || null,
        imageUrl,
        priceBefore: numOrNull('oPriceBefore'),
        priceAfter: numOrNull('oPriceAfter'),
        code: document.getElementById('oCode').value.trim() || null,
        startsAtUtc: dtOrNull('oStart'),
        endsAtUtc: dtOrNull('oEnd'),
        isActive: document.getElementById('oActive').checked,
        categoryIds: (this.selectedCategoryIds||[]).map(Number).filter(x=>Number.isFinite(x) && x>0),
        productIds: (this.selectedProductIds||[]).map(Number).filter(x=>Number.isFinite(x) && x>0)
      };

      const res = await fetch('/api/admin/offers',{method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(payload)});
      const data = await res.json().catch(()=>({}));
      if(!res.ok){ toast('خطأ', (data.error || 'فشل حفظ العرض')); this.saving=false; if(btn){btn.disabled=false;btn.innerText='حفظ';} return; }

      toast('تم','تم حفظ العرض');
      this.modal.hide();
      await this.load();
      this.saving = false;
      if(btn){ btn.disabled = false; btn.innerText = 'حفظ'; }
    },

    async del(id){
      if(!confirm('حذف العرض؟')) return;
      const res = await fetch(`/api/admin/offers/${id}`,{method:'DELETE'});
      const data = await res.json().catch(()=>({}));
      if(!res.ok){ toast('خطأ', (data.error || 'فشل حذف العرض')); return; }
      toast('تم','تم حذف العرض');
      await this.load();
    }
  };

  async function uploadAsset(kind, file){
    const fd = new FormData();
    fd.append('file', file);
    const res = await fetch(`/api/admin/upload/asset?kind=${encodeURIComponent(kind)}`, { method:'POST', body: fd });
    if(!res.ok) throw new Error('فشل رفع الصورة');
    const j = await res.json();
    return j.url;
  }

  function dtOrNull(id){
    const v = document.getElementById(id).value;
    if(!v) return null;
    return new Date(v).toISOString();
  }

  function toLocalInput(iso){
    const d = new Date(iso);
    const pad = (x)=>`${x}`.padStart(2,'0');
    return `${d.getFullYear()}-${pad(d.getMonth()+1)}-${pad(d.getDate())}T${pad(d.getHours())}:${pad(d.getMinutes())}`;
  }

  function fillOffer(o){
    document.getElementById('offerModalTitle').innerText = o.id? `تعديل عرض #${o.id}`: 'إضافة عرض';
    document.getElementById('oTitle').value = o.title || '';
    document.getElementById('oDesc').value = o.description || '';
    document.getElementById('oPriceBefore').value = (o.priceBefore ?? '');
    document.getElementById('oPriceAfter').value = (o.priceAfter ?? '');
    document.getElementById('oCode').value = o.code || '';
    document.getElementById('oStart').value = o.startsAtUtc? toLocalInput(o.startsAtUtc): '';
    document.getElementById('oEnd').value = o.endsAtUtc? toLocalInput(o.endsAtUtc): '';
    document.getElementById('oActive').checked = !!o.isActive;
    document.getElementById('oImageFile').value = '';
    document.getElementById('oImagePreview').innerHTML = o.imageUrl ? `<img src="${o.imageUrl}" style="max-width: 100%; max-height: 240px; border-radius: 12px; object-fit: cover;" />` : '';

    // Scope selection
    ui.selectedCategoryIds = Array.isArray(o.categoryIds) ? [...o.categoryIds] : (ui.selectedCategoryIds||[]);
    ui.selectedProductIds = Array.isArray(o.productIds) ? [...o.productIds] : (ui.selectedProductIds||[]);
    renderScopeLists();
  }

  function renderScopeLists(){
    const cats = ui.menu.categories || [];
    const prods = ui.menu.products || [];
    const catQ = (document.getElementById('catSearch')?.value || '').trim().toLowerCase();
    const prodQ = (document.getElementById('prodSearch')?.value || '').trim().toLowerCase();

    const catList = document.getElementById('catList');
    const prodList = document.getElementById('prodList');
    if(catList){
      const filtered = cats.filter(c=>!catQ || (c.name||'').toLowerCase().includes(catQ));
      catList.innerHTML = filtered.map(c=>{
        const checked = ui.selectedCategoryIds.includes(c.id);
        return `<label class="d-flex align-items-center gap-2 py-1" style="cursor:pointer">
          <input type="checkbox" class="form-check-input m-0" data-kind="cat" data-id="${c.id}" ${checked?'checked':''} />
          <span>${escapeHtml(c.name||'')}</span>
        </label>`;
      }).join('') || '<div class="text-muted small">لا يوجد أقسام</div>';
    }

    if(prodList){
      const filtered = prods.filter(p=>!prodQ || (p.name||'').toLowerCase().includes(prodQ));
      prodList.innerHTML = filtered.map(p=>{
        const checked = ui.selectedProductIds.includes(p.id);
        const price = Number(p.price||0);
        return `<label class="d-flex align-items-center justify-content-between gap-2 py-1" style="cursor:pointer">
          <span class="d-flex align-items-center gap-2">
            <input type="checkbox" class="form-check-input m-0" data-kind="prod" data-id="${p.id}" ${checked?'checked':''} />
            <span>${escapeHtml(p.name||'')}</span>
          </span>
          <span class="text-muted small">${Number.isFinite(price)? price.toFixed(2): ''}</span>
        </label>`;
      }).join('') || '<div class="text-muted small">لا يوجد منتجات</div>';
    }

    renderSelectedBadges();
  }

  function renderSelectedBadges(){
    const catBox = document.getElementById('catSelected');
    const prodBox = document.getElementById('prodSelected');
    if(catBox){
      if(!ui.selectedCategoryIds.length){ catBox.innerHTML = '<span class="text-muted">لم يتم اختيار أقسام</span>'; }
      else {
        const map = new Map((ui.menu.categories||[]).map(c=>[c.id, c.name]));
        catBox.innerHTML = ui.selectedCategoryIds.map(id=>`<span class="badge bg-light text-dark border me-1">${escapeHtml(map.get(id)||('#'+id))}</span>`).join('');
      }
    }
    if(prodBox){
      if(!ui.selectedProductIds.length){ prodBox.innerHTML = '<span class="text-muted">لم يتم اختيار منتجات</span>'; }
      else {
        const map = new Map((ui.menu.products||[]).map(p=>[p.id, p.name]));
        prodBox.innerHTML = ui.selectedProductIds.map(id=>`<span class="badge bg-light text-dark border me-1">${escapeHtml(map.get(id)||('#'+id))}</span>`).join('');
      }
    }
  }

  function bindScopeEvents(){
    document.getElementById('catSearch')?.addEventListener('input', ()=>renderScopeLists());
    document.getElementById('prodSearch')?.addEventListener('input', ()=>renderScopeLists());

    document.getElementById('catList')?.addEventListener('change', (e)=>{
      const t = e.target;
      if(!(t instanceof HTMLInputElement) || t.dataset.kind!=='cat') return;
      const id = Number(t.dataset.id);
      if(!Number.isFinite(id)) return;
      if(t.checked){ if(!ui.selectedCategoryIds.includes(id)) ui.selectedCategoryIds.push(id); }
      else { ui.selectedCategoryIds = ui.selectedCategoryIds.filter(x=>x!==id); }
      renderSelectedBadges();
    });

    document.getElementById('prodList')?.addEventListener('change', (e)=>{
      const t = e.target;
      if(!(t instanceof HTMLInputElement) || t.dataset.kind!=='prod') return;
      const id = Number(t.dataset.id);
      if(!Number.isFinite(id)) return;
      if(t.checked){ if(!ui.selectedProductIds.includes(id)) ui.selectedProductIds.push(id); }
      else { ui.selectedProductIds = ui.selectedProductIds.filter(x=>x!==id); }
      renderSelectedBadges();
    });
  }

  function escapeHtml(s){
    return (s||'').toString().replace(/[&<>"']/g, (c)=>({
      '&':'&amp;',
      '<':'&lt;',
      '>':'&gt;',
      '"':'&quot;',
      "'":'&#39;'
    }[c]||c));
  }

  function numOrNull(id){
    const v = (document.getElementById(id).value || '').trim();
    if(!v) return null;
    const n = Number(v);
    return Number.isFinite(n) ? n : null;
  }

  document.addEventListener('DOMContentLoaded', ()=>{
    ui.modal = new bootstrap.Modal(document.getElementById('offerModal'));
    bindScopeEvents();
    ui.load();
    ui.loadMenu();
  });
</script>
}