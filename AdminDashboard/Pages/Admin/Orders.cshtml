@page
@model AdminDashboard.Pages.Admin.AdminPageModel

<div class="admin-page-header">
  <div class="page-icon"><i class="bi bi-bag-check"></i></div>
  <div>
    <h1 class="page-title">إدارة الطلبات</h1>
    <p class="page-subtitle">متابعة الطلبات والتعيين والوقت المتوقع</p>
  </div>
</div>

<div class="admin-card">
  <div class="admin-card-header">
    <span>الطلبات الأخيرة</span>
    <div class="d-flex gap-2 align-items-center flex-wrap">
      <select class="form-select form-select-sm" id="bulkDriver" style="min-width:220px"><option value="">اختر سائق...</option></select>
      <button class="btn btn-sm btn-success" id="btnBulkAssign" disabled>تعيين للسائق</button>
      <button class="btn btn-sm btn-warning text-dark" id="btnManualOrder" title="إضافة طلب يدوي من اللوحة"><i class="bi bi-plus-circle me-1"></i>طلب يدوي</button>
      <button class="btn btn-sm btn-danger" id="btnDeleteAll" onclick="deleteAllOrders()">حذف الكل</button>
      <button class="btn btn-sm btn-primary" id="btnRefresh"><i class="bi bi-arrow-clockwise me-1"></i>تحديث</button>
    </div>
  </div>
  <div class="admin-card-body p-0">
  <div class="table-responsive orders-table-responsive">
    <table class="table table-hover table-sm align-middle mb-0 orders-data-table" id="tbl">
      <thead class="table-light"><tr><th class="text-center order-col-chk"><input type="checkbox" id="chkAll" /></th><th class="order-col-id">#</th><th class="order-col-status">الحالة</th><th class="order-col-eta">الوقت</th><th class="order-col-total">المبلغ</th><th class="order-col-km">كم</th><th class="order-col-customer">الزبون</th><th class="order-col-driver">السائق</th><th class="order-col-actions text-center">إجراءات</th></tr></thead>
      <tbody></tbody>
    </table>
  </div>
  </div>
</div>

<div class="modal fade" id="assignModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header"><h5 class="modal-title">تعيين سائق</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
      <div class="modal-body">
        <input type="hidden" id="orderId" />
        <select class="form-select" id="drivers"></select>
      </div>
      <div class="modal-footer">
        <button class="btn btn-outline-secondary" data-bs-dismiss="modal">إلغاء</button>
        <button class="btn btn-primary" id="btnAssign">حفظ</button>
      </div>
    </div>
  </div>
</div>

<div class="modal fade" id="etaModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header"><h5 class="modal-title">تحديد وقت التوصيل المتوقع</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
      <div class="modal-body">
        <input type="hidden" id="etaOrderId" />
        <div class="row g-2">
          <input type="hidden" id="prepEta" value="0" />
          <div class="col-12">
            <label class="form-label">مدة التوصيل (دقيقة)</label>
            <input class="form-control" type="number" min="0" max="600" id="deliveryEta" placeholder="مثلاً 20" />
          </div>
        </div>
        <div class="form-text mt-2">سيظهر للزبون الوقت المتوقع لوصول الطلب.</div>
      </div>
      <div class="modal-footer">
        <button class="btn btn-outline-secondary" data-bs-dismiss="modal">إلغاء</button>
        <button class="btn btn-primary" id="btnSaveEta">حفظ</button>
      </div>
    </div>
  </div>
</div>

<div class="modal fade" id="modalEditOrder" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">تعديل الطلب (بدون وقت)</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <input type="hidden" id="editOrderId" />
        <div class="mb-2 text-muted">الزبون: <span id="editOrderCustomer" class="fw-semibold"></span></div>

        <div class="row g-2">
          <div class="col-md-6">
            <label class="form-label">العنوان</label>
            <input class="form-control" id="editOrderAddress" />
          </div>
          <div class="col-md-3">
            <label class="form-label">خط العرض</label>
            <input class="form-control" id="editOrderLat" />
          </div>
          <div class="col-md-3">
            <label class="form-label">خط الطول</label>
            <input class="form-control" id="editOrderLng" />
          </div>
        </div>

        <div class="row g-2 mt-2">
          <div class="col-md-4">
            <label class="form-label">المسافة (كم)</label>
            <input class="form-control" id="editOrderDistanceKm" readonly placeholder="—" />
          </div>
        </div>

        <div class="mt-2">
          <label class="form-label">ملاحظة الطلب</label>
          <input class="form-control" id="editOrderNotes" />
        </div>

        <div class="mt-3">
          <label class="form-label mb-2">الأصناف</label>
          <div class="table-responsive">
            <table class="table table-sm table-bordered" id="editOrderItemsTable">
              <thead class="table-light">
                <tr>
                  <th>الصنف</th>
                  <th class="text-center" style="width:100px">الكمية</th>
                  <th class="text-center" style="width:60px">حذف</th>
                </tr>
              </thead>
              <tbody id="editOrderItemsBody"></tbody>
            </table>
          </div>
          <div class="mt-2 d-flex flex-wrap align-items-end gap-2">
            <div class="d-flex align-items-end gap-2 flex-grow-1 flex-wrap">
              <div style="min-width:200px;">
                <label class="form-label small mb-1">إضافة صنف</label>
                <select class="form-select form-select-sm" id="editOrderAddProduct">
                  <option value="">اختر صنفاً...</option>
                </select>
              </div>
              <div style="width:90px;">
                <label class="form-label small mb-1">الكمية</label>
                <input type="number" class="form-control form-control-sm" id="editOrderAddQty" min="1" max="99" value="1" />
              </div>
              <button type="button" class="btn btn-sm btn-outline-primary" id="btnEditOrderAddItem"><i class="bi bi-plus-lg me-1"></i>إضافة صنف</button>
            </div>
          </div>
          <p class="form-text small text-muted mb-0 mt-2">يمكنك تعديل الكمية، حذف صنف، أو إضافة أصناف جديدة من القائمة.</p>
        </div>
      </div>
      <div class="modal-footer">
        <button class="btn btn-outline-secondary" data-bs-dismiss="modal">إلغاء</button>
        <button class="btn btn-warning" onclick="saveEditOrder()">حفظ التعديل</button>
      </div>
    </div>
  </div>
</div>

<div class="modal fade" id="modalManualOrder" tabindex="-1">
  <div class="modal-dialog modal-lg modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><i class="bi bi-plus-circle me-2"></i>إضافة طلب يدوي</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div class="row g-2 mb-3">
          <div class="col-md-6">
            <label class="form-label">اسم الزبون <span class="text-danger">*</span></label>
            <input type="text" class="form-control" id="manualCustomerName" placeholder="اسم العميل" />
          </div>
          <div class="col-md-6">
            <label class="form-label">رقم الهاتف <span class="text-danger">*</span></label>
            <input type="text" class="form-control" id="manualCustomerPhone" placeholder="05xxxxxxxx" dir="ltr" />
          </div>
        </div>
        <div class="row g-2 mb-3">
          <div class="col-md-8">
            <label class="form-label">عنوان التوصيل</label>
            <input type="text" class="form-control" id="manualDeliveryAddress" placeholder="اختياري" />
          </div>
        </div>
        <div class="mb-3">
          <label class="form-label">ملاحظة</label>
          <input type="text" class="form-control" id="manualNotes" placeholder="اختياري" />
        </div>
        <div class="mb-2 d-flex justify-content-between align-items-center">
          <label class="form-label mb-0 fw-bold">الأصناف <span class="text-danger">*</span></label>
          <button type="button" class="btn btn-sm btn-outline-primary" id="btnAddManualItem"><i class="bi bi-plus me-1"></i>إضافة صنف</button>
        </div>
        <div class="table-responsive">
          <table class="table table-sm table-bordered">
            <thead class="table-light">
              <tr>
                <th style="width:55%">الصنف</th>
                <th class="text-center" style="width:25%">الكمية</th>
                <th class="text-center" style="width:20%">إجراء</th>
              </tr>
            </thead>
            <tbody id="manualOrderItemsBody"></tbody>
          </table>
        </div>
        <p class="form-text small text-muted mb-0">يجب إضافة صنف واحد على الأقل. يتم إنشاء الزبون تلقائياً إن لم يكن مسجلاً بالرقم.</p>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">إلغاء</button>
        <button type="button" class="btn btn-warning text-dark" id="btnSubmitManualOrder"><i class="bi bi-check2 me-1"></i>إنشاء الطلب</button>
      </div>
    </div>
  </div>
</div>

<div class="modal fade" id="modalOrderActions" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered" style="max-width:380px">
    <div class="modal-content border-0 shadow-lg" style="border-radius:18px;overflow:hidden">
      <div class="modal-header border-0 pb-0 px-4 pt-4">
        <div class="d-flex align-items-center gap-2">
          <div style="width:36px;height:36px;border-radius:10px;background:linear-gradient(135deg,#4f46e5,#7c3aed);display:flex;align-items:center;justify-content:center">
            <i class="bi bi-lightning-charge-fill text-white" style="font-size:16px"></i>
          </div>
          <div>
            <h6 class="modal-title fw-bold mb-0">إجراءات الطلب</h6>
            <small class="text-muted" id="modalOrderActionsSubtitle"></small>
          </div>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body px-4 pb-4 pt-3" id="modalOrderActionsBody">
        <!-- تُملأ ديناميكياً عند فتح النافذة -->
      </div>
    </div>
  </div>
</div>

<div class="modal fade" id="modalViewOrder" tabindex="-1">
  <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
    <div class="modal-content border-0" style="border-radius:16px; overflow:hidden;">
      <div class="modal-header text-white border-0" style="background: linear-gradient(135deg, #b8860b 0%, #daa520 50%, #b8860b 100%); padding: 1.5rem 1.5rem 1rem;">
        <div class="d-flex align-items-center gap-3">
          <div style="background:rgba(255,255,255,0.2); border-radius:50%; width:48px; height:48px; display:flex; align-items:center; justify-content:center;">
            <i class="bi bi-receipt fs-5"></i>
          </div>
          <div>
            <h5 class="modal-title mb-0 fw-bold" id="viewOrderTitle">تفاصيل الطلب</h5>
            <small id="viewOrderDate" class="opacity-75"></small>
          </div>
        </div>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body p-0" id="viewOrderBody" style="background:#f8f9fa;">
        <div class="text-center py-5"><div class="spinner-border" style="color:#daa520;"></div></div>
      </div>
      <div class="modal-footer border-0" style="background:#f8f9fa;">
        <button class="btn btn-outline-secondary" data-bs-dismiss="modal">إغلاق</button>
      </div>
    </div>
  </div>
</div>

@section Scripts {
<script>
const tblBody = document.querySelector('#tbl tbody');
const assignModal = new bootstrap.Modal(document.getElementById('assignModal'));
const driversSelect = document.getElementById('drivers');
const bulkDriverSelect = document.getElementById('bulkDriver');
const btnBulkAssign = document.getElementById('btnBulkAssign');
const chkAll = document.getElementById('chkAll');
const selectedIds = new Set();
let _ordersList = [];
let _orderActionsModal = null;

async function loadDrivers(){
  const res = await fetch('/api/admin/drivers');
  if(!res.ok) return [];
  return await res.json();
}

const driverStatusTxt = (st)=> ['متاح','مشغول','غير متاح'][st] || '';
async function fillDrivers(selectEl){
  const drivers = await loadDrivers();
  selectEl.innerHTML = ['<option value="">اختر سائق</option>'].concat(drivers.map(d=>`<option value="${d.id}">#${d.id} - ${d.name} (${driverStatusTxt(d.status)})</option>`)).join('');
}

const statusName = (s)=>['طلب جديد','مؤكد','قيد التجهيز','جاهز للشحن','مع السائق','تم التوصيل','تم الإلغاء'][s] || s;
const statusBadge = (s)=>(['primary','success','warning','info','secondary','success','danger'][s]||'secondary');

// ——— ETA Modal ———
const etaModal = new bootstrap.Modal(document.getElementById('etaModal'));
document.getElementById('btnSaveEta').addEventListener('click', async()=>{
  const orderId = parseInt(document.getElementById('etaOrderId').value);
  const prep = parseInt(document.getElementById('prepEta').value)||0;
  const delivery = parseInt(document.getElementById('deliveryEta').value)||0;
  const res = await fetch('/api/admin/order-eta',{
    method:'POST',
    headers:{'Content-Type':'application/json'},
    body: JSON.stringify({orderId, prepEtaMinutes: prep, deliveryEtaMinutes: delivery})
  });
  if(res.ok){ etaModal.hide(); load(); }
});

// ——— Edit Order ———
let _editOrderItems = [];
let _editOrderProducts = [];
let _editOrderModal = null;

function renderEditOrderItems(items){
  const tbody = document.getElementById('editOrderItemsBody');
  if(!tbody) return;
  tbody.innerHTML = items.map((it,i)=>`<tr>
    <td>${it.productNameSnapshot||('صنف #'+it.productId)}</td>
    <td class="text-center"><input type="number" class="form-control form-control-sm edit-item-qty" data-idx="${i}" value="${it.quantity}" min="1" max="99" style="width:70px;margin:0 auto;" /></td>
    <td class="text-center"><button type="button" class="btn btn-sm btn-outline-danger edit-item-del" data-idx="${i}"><i class="bi bi-trash"></i></button></td>
  </tr>`).join('');
  tbody.querySelectorAll('.edit-item-qty').forEach(el=>{
    el.addEventListener('change',function(){ _editOrderItems[parseInt(this.dataset.idx)].quantity = parseInt(this.value)||1; });
  });
  tbody.querySelectorAll('.edit-item-del').forEach(el=>{
    el.addEventListener('click',function(){ _editOrderItems.splice(parseInt(this.dataset.idx),1); renderEditOrderItems(_editOrderItems); });
  });
}

async function openEditOrder(orderId){
  const res = await fetch(`/api/admin/order/${orderId}`);
  if(!res.ok){ alert('تعذر تحميل الطلب'); return; }
  const o = await res.json();
  document.getElementById('editOrderId').value = orderId;
  document.getElementById('editOrderCustomer').textContent = o.customerName||('زبون #'+o.customerId);
  document.getElementById('editOrderAddress').value = o.deliveryAddress||'';
  document.getElementById('editOrderLat').value = o.deliveryLat||'';
  document.getElementById('editOrderLng').value = o.deliveryLng||'';
  document.getElementById('editOrderDistanceKm').value = o.deliveryDistanceKm!=null?Number(o.deliveryDistanceKm).toFixed(3):'';
  document.getElementById('editOrderNotes').value = o.notes||'';
  _editOrderItems = (o.items||[]).map(i=>({productId:i.productId,quantity:i.quantity||1,optionsSnapshot:i.optionsSnapshot,productNameSnapshot:i.productNameSnapshot||('صنف #'+i.productId),unitPriceSnapshot:i.unitPriceSnapshot||0}));
  renderEditOrderItems(_editOrderItems);
  // Load products for the add-product dropdown
  const prodSel = document.getElementById('editOrderAddProduct');
  if(_editOrderProducts.length===0){
    const mr = await fetch('/api/admin/menu');
    if(mr.ok){ const md=await mr.json(); _editOrderProducts=(md.products||[]).filter(p=>p.isActive!==false); }
  }
  prodSel.innerHTML='<option value="">اختر صنفاً...</option>'+_editOrderProducts.map(p=>`<option value="${p.id}">${p.name||('صنف #'+p.id)} — ${Number(p.price||0).toFixed(0)}</option>`).join('');
  if(!_editOrderModal) _editOrderModal=new bootstrap.Modal(document.getElementById('modalEditOrder'));
  _editOrderModal.show();
}

window.saveEditOrder = async function(){
  const orderId = parseInt(document.getElementById('editOrderId').value);
  if(isNaN(orderId)) return;
  const payload = {
    deliveryAddress: document.getElementById('editOrderAddress').value.trim()||null,
    deliveryLat: parseFloat(document.getElementById('editOrderLat').value)||null,
    deliveryLng: parseFloat(document.getElementById('editOrderLng').value)||null,
    notes: document.getElementById('editOrderNotes').value.trim()||null,
    items: _editOrderItems.map(it=>({productId:it.productId,quantity:it.quantity,optionsSnapshot:it.optionsSnapshot}))
  };
  const res = await fetch(`/api/admin/order/${orderId}/edit`,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)});
  if(res.ok){ _editOrderModal?.hide(); load(); }
  else { const j=await res.json().catch(()=>({})); alert(j.message||'فشل الحفظ'); }
};

// ——— Main load function ———
async function load(){
  const res = await fetch('/api/admin/orders');
  if(!res.ok){
    tblBody.innerHTML=`<tr><td colspan="10" class="text-center text-danger py-3">فشل تحميل الطلبات (${res.status})</td></tr>`;
    return;
  }
  const orders = await res.json();
  _ordersList = orders;
  if(!orders.length){
    tblBody.innerHTML='<tr><td colspan="10" class="text-center text-muted py-4">لا توجد طلبات حالياً</td></tr>';
    return;
  }
  const driversList = await loadDrivers();
  const driverMap = {};
  driversList.forEach(d=>{ driverMap[d.id]=d.name; });
  tblBody.innerHTML = orders.map(o=>{
    const st = o.currentStatus||0;
    const badge = statusBadge(st);
    const name = statusName(st);
    const custName = o.customerName||(o.customerId?'#'+o.customerId:'—');
    const driverName = o.driverId?(driverMap[o.driverId]||('#'+o.driverId)):'—';
    const total = Number(o.total||0).toFixed(2);
    const km = o.deliveryDistanceKm!=null?Number(o.deliveryDistanceKm).toFixed(1)+'كم':'—';
    const checked = selectedIds.has(o.id)?'checked':'';
    return `<tr>
      <td class="text-center order-col-chk"><input type="checkbox" class="row-chk" data-id="${o.id}" ${checked}/></td>
      <td class="order-col-id"><a href="#" onclick="openViewOrder(${o.id});return false;" class="fw-bold text-decoration-none">#${o.id}</a></td>
      <td class="order-col-status"><span class="badge bg-${badge}">${name}</span>${o.wasEditedByCustomer?'<span class="badge bg-warning text-dark ms-1 small">معدّل</span>':''}</td>
      <td class="order-col-eta">${o.prepEtaMinutes!=null?o.prepEtaMinutes+'د':'—'} / ${o.deliveryEtaMinutes!=null?o.deliveryEtaMinutes+'د':'—'}</td>
      <td class="order-col-total">${total}</td>
      <td class="order-col-km">${km}</td>
      <td class="order-col-customer">${escHtml(custName)}${o.customerPhone?`<div class="small text-muted">${escHtml(o.customerPhone)}</div>`:''}</td>
      <td class="order-col-driver">${escHtml(driverName)}</td>
      <td class="order-col-actions text-center">
        <button class="btn btn-xs btn-outline-secondary" onclick="openOrderActions(${o.id})" title="إجراءات"><i class="bi bi-three-dots-vertical"></i></button>
      </td>
    </tr>`;
  }).join('');
  tblBody.querySelectorAll('.row-chk').forEach(chk=>{
    chk.addEventListener('change',function(){
      const id=parseInt(this.dataset.id);
      if(this.checked) selectedIds.add(id); else selectedIds.delete(id);
      btnBulkAssign.disabled=selectedIds.size===0;
    });
  });
}

function escHtml(s){
  if(!s) return '';
  return s.toString().replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

// ——— Order Actions ———
window.openOrderActions = function(orderId){
  const o = _ordersList.find(x=>x.id===orderId);
  if(!o) return;
  const body = document.getElementById('modalOrderActionsBody');
  const subtitle = document.getElementById('modalOrderActionsSubtitle');
  if(subtitle) subtitle.textContent = `طلب #${orderId}`;
  const st = o.currentStatus||0;
  const canEdit = st<5;
  const statusOptions = [
    {label:'طلب جديد',val:0,icon:'bi-inbox',color:'#6c757d'},
    {label:'مؤكد',val:1,icon:'bi-check-circle',color:'#198754'},
    {label:'قيد التجهيز',val:2,icon:'bi-gear',color:'#fd7e14'},
    {label:'جاهز للشحن',val:3,icon:'bi-box-seam',color:'#0dcaf0'},
    {label:'مع السائق',val:4,icon:'bi-bicycle',color:'#6f42c1'},
    {label:'تم التوصيل',val:5,icon:'bi-check2-all',color:'#0d6efd'},
    {label:'ملغي',val:6,icon:'bi-x-circle',color:'#dc3545'}
  ];

  const actionBtn = (icon, label, onclick, colorClass, extraStyle='') =>
    `<button class="d-flex align-items-center gap-3 w-100 border-0 rounded-3 px-3 py-2 mb-2 ${colorClass}" style="background:rgba(255,255,255,0.04);transition:background .15s;cursor:pointer;text-align:right;${extraStyle}" onclick="${onclick}" onmouseover="this.style.background='rgba(255,255,255,0.09)'" onmouseout="this.style.background='rgba(255,255,255,0.04)'">
      <i class="bi ${icon}" style="font-size:18px;width:22px;flex-shrink:0"></i>
      <span style="font-size:14px;font-weight:600">${label}</span>
    </button>`;

  const statusPill = (opt) => st === opt.val ? '' :
    `<button onclick="changeStatus(${orderId},${opt.val})" title="${opt.label}"
      style="border:1.5px solid ${opt.color}22;background:${opt.color}15;color:${opt.color};border-radius:20px;padding:4px 14px;font-size:12px;font-weight:700;cursor:pointer;transition:all .15s;white-space:nowrap"
      onmouseover="this.style.background='${opt.color}30'" onmouseout="this.style.background='${opt.color}15'">
      <i class="bi ${opt.icon} me-1"></i>${opt.label}
    </button>`;

  body.innerHTML=`
    <div>
      <div class="mb-3">
        ${actionBtn('bi-person-check-fill','تعيين سائق',`openAssign(${orderId})`,'text-primary')}
