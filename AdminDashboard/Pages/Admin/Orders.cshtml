document.getElementById('btnSubmitManualOrder').addEventListener('click', async function(){
  const customerName = (document.getElementById('manualCustomerName').value || '').trim();
  const customerPhone = (document.getElementById('manualCustomerPhone').value || '').trim();
  if(!customerName){ alert('يرجى إدخال اسم الزبون'); return; }
  if(!customerPhone){ alert('يرجى إدخال رقم هاتف الزبون'); return; }
  const rows = document.querySelectorAll('#manualOrderItemsBody tr');
  const items = [];
  for(const tr of rows){
    const productId = parseInt(tr.querySelector('.manual-item-product')?.value, 10);
    const qty = parseInt(tr.querySelector('.manual-item-qty')?.value, 10) || 1;
    if(!(productId > 0 && qty >= 1)) continue;
    const varInput = tr.querySelector('.manual-item-variant:checked');
    const addonInputs = tr.querySelectorAll('.manual-item-addon:checked');
    const variantId = varInput ? parseInt(varInput.value, 10) : null;
    const addonIds = Array.from(addonInputs)
      .map(el => parseInt(el.value, 10))
      .filter(v => !isNaN(v));
    let optionsSnapshot = null;
    const optObj = {};
    if(variantId && !isNaN(variantId)) optObj.variantId = variantId;
    if(addonIds.length) optObj.addonIds = addonIds;
    if(Object.keys(optObj).length) optionsSnapshot = JSON.stringify(optObj);
    const item = { productId, quantity: qty };
    if(optionsSnapshot) item.optionsSnapshot = optionsSnapshot;
    items.push(item);
  }
  if(items.length === 0){ alert('يرجى إضافة صنف واحد على الأقل'); return; }
  const payload = {
    customerName,
    customerPhone,
    deliveryAddress: (document.getElementById('manualDeliveryAddress').value || '').trim() || null,
    notes: (document.getElementById('manualNotes').value || '').trim() || null,
    items
  };
  this.disabled = true;
  try {
    const res = await fetch('/api/admin/manual-order', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) });
    const data = await res.json().catch(() => ({}));
    if(!res.ok){
      alert(data.message || 'فشل إنشاء الطلب');
      return;
    }
    manualOrderModal.hide();
    await load();
    if(window.adminToast) window.adminToast('تم إنشاء الطلب', 'تم إضافة الطلب #' + (data.id || '') + ' بنجاح', 'success');
    else alert('تم إنشاء الطلب #' + (data.id || '') + ' بنجاح');
  } catch(e){
    console.error(e);
    alert('حدث خطأ أثناء إنشاء الطلب');
  } finally {
    this.disabled = false;
  }
});

