      <div class="p-3 pb-0">
        <div class="d-flex flex-wrap gap-2 mb-3">
          <span class="badge bg-${statusColor} fs-6 px-3 py-2">${statusLabel}</span>
          ${o.wasEditedByCustomer ? '<span class="badge bg-warning text-dark fs-6 px-3 py-2">تم تعديل الطلب من الزبون</span>' : ''}
        </div>
        <div class="row g-3 mb-3">
          <div class="col-sm-6">
            <div class="rounded-3 p-3 h-100" style="background:white; border:1px solid #e9ecef;">
              <div class="text-muted small mb-2"><i class="bi bi-person-circle me-1"></i>معلومات الزبون</div>
              <div class="fw-bold fs-6">${o.customerName || ('زبون #' + o.customerId)}</div>
              ${o.customerPhone ? `<div class="mt-1"><a href="tel:${o.customerPhone}" class="text-decoration-none"><i class="bi bi-telephone me-1" style="color:#daa520;"></i>${o.customerPhone}</a></div>` : ''}
            </div>
          </div>
          <div class="col-sm-6">
            <div class="rounded-3 p-3 h-100" style="background:white; border:1px solid #e9ecef;">
              <div class="text-muted small mb-2"><i class="bi bi-truck me-1"></i>معلومات التوصيل</div>
