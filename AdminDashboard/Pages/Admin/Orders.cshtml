let manualOrderProducts = [];
let manualOrderVariantsByProduct = {};
let manualOrderAddonsByProduct = {};
let manualOrderModal = null;

async function loadManualOrderProducts(){
  const res = await fetch('/api/admin/menu');
  if(!res.ok) return [];
  const data = await res.json();
  const prods = (data.products || []).filter(p => p.isActive !== false).map(p => ({ id: p.id, name: p.name || ('صنف #' + p.id), price: p.price || 0 }));
  manualOrderVariantsByProduct = {};
  (data.variants || []).forEach(v => {
    if(v.isActive === false) return;
    const pid = v.productId;
    if(!manualOrderVariantsByProduct[pid]) manualOrderVariantsByProduct[pid] = [];
    manualOrderVariantsByProduct[pid].push(v);
  });
  manualOrderAddonsByProduct = {};
  (data.addons || []).forEach(a => {
    if(a.isActive === false) return;
    const pid = a.productId;
    if(!manualOrderAddonsByProduct[pid]) manualOrderAddonsByProduct[pid] = [];
    manualOrderAddonsByProduct[pid].push(a);
  });
  return prods;
}

function renderManualOrderRow(index, products, selectedId, qty){
  const opts = products.map(p => `<option value="${p.id}" ${p.id === selectedId ? 'selected' : ''}>${p.name} — ${Number(p.price).toFixed(0)} ل.س</option>`).join('');
  return `<tr data-idx="${index}">
    <td>
      <select class="form-select form-select-sm manual-item-product">${opts ? '<option value="">اختر صنفاً</option>' + opts : '<option value="">لا توجد أصناف</option>'}</select>
      <div class="mt-1 small text-muted manual-item-options"></div>
    </td>
    <td class="text-center"><input type="number" class="form-control form-control-sm manual-item-qty" min="1" max="99" value="${qty || 1}" style="width:70px;margin:0 auto;" /></td>
    <td class="text-center"><button type="button" class="btn btn-sm btn-outline-danger btn-remove-manual-item" title="حذف"><i class="bi bi-trash"></i></button></td>
  </tr>`;
}

function renderManualOptionsForRow(tr){
  const prodSelect = tr.querySelector('.manual-item-product');
  const container = tr.querySelector('.manual-item-options');
  if(!prodSelect || !container) return;
  const productId = parseInt(prodSelect.value, 10);
  if(!productId){
    container.innerHTML = '';
    return;
  }
  const vars = manualOrderVariantsByProduct[productId] || [];
  const adds = manualOrderAddonsByProduct[productId] || [];
  if(vars.length === 0 && adds.length === 0){
    container.innerHTML = '<span class="text-muted">لا توجد أنواع أو إضافات لهذا الصنف.</span>';
    return;
  }
  const idx = tr.getAttribute('data-idx') || '0';
  let html = '';
  if(vars.length){
    html += '<div class="mb-1"><span class="d-block mb-1">النوع:</span>';
    vars.forEach(v => {
      const id = v.id;
      const name = (v.name || '').toString();
      const delta = Number(v.priceDelta || 0);
      const label = delta === 0 ? name : `${name} (+${delta.toFixed(0)})`;
      const inputId = `manual-var-${idx}-${id}`;
      html += `<div class="form-check form-check-inline mb-0">
        <input class="form-check-input manual-item-variant" type="radio" name="manualVar_${idx}" id="${inputId}" value="${id}">
        <label class="form-check-label small" for="${inputId}">${label}</label>
      </div>`;
    });
    html += '</div>';
  }
  if(adds.length){
    html += '<div><span class="d-block mb-1">الإضافات:</span>';
    adds.forEach(a => {
      const id = a.id;
      const name = (a.name || '').toString();
      const price = Number(a.price || 0);
      const inputId = `manual-add-${idx}-${id}`;
      html += `<div class="form-check form-check-inline mb-0">
        <input class="form-check-input manual-item-addon" type="checkbox" id="${inputId}" value="${id}">
        <label class="form-check-label small" for="${inputId}">${name}${price ? ` (+${price.toFixed(0)})` : ''}</label>
      </div>`;
    });
    html += '</div>';
  }
  container.innerHTML = html;
}

function addManualOrderRow(selectedId, qty){
  const tbody = document.getElementById('manualOrderItemsBody');
  const idx = tbody.querySelectorAll('tr').length;
  tbody.insertAdjacentHTML('beforeend', renderManualOrderRow(idx, manualOrderProducts, selectedId, qty || 1));
  const tr = tbody.querySelector('tr:last-child');
  if(!tr) return;
  tr.setAttribute('data-idx', String(idx));
  tr.querySelector('.btn-remove-manual-item')?.addEventListener('click', function(){
    this.closest('tr')?.remove();
  });
  const prodSelect = tr.querySelector('.manual-item-product');
  if(prodSelect){
    prodSelect.addEventListener('change', function(){
      renderManualOptionsForRow(tr);
    });
  }

  renderManualOptionsForRow(tr);
}

