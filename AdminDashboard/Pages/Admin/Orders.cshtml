  viewOrderModal.show();
  try {
    const res = await fetch(`/api/admin/order/${orderId}`, { credentials: 'same-origin' });
    if (!res.ok) { document.getElementById('viewOrderBody').innerHTML = '<div class="text-center py-5 text-danger"><i class="bi bi-exclamation-circle fs-3"></i><p class="mt-2">تعذر تحميل تفاصيل الطلب</p></div>'; return; }
