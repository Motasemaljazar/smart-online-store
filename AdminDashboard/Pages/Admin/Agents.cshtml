@page
@model AdminDashboard.Pages.Admin.AdminPageModel
@{
    ViewData["Title"] = "المندوبون";
}

<div class="admin-page-header">
  <div class="page-icon"><i class="bi bi-person-badge"></i></div>
  <div>
    <h1 class="page-title">إدارة المندوبين</h1>
    <p class="page-subtitle">إضافة وتعديل المندوبين وبيانات تسجيل دخولهم</p>
  </div>
</div>

<div id="agentStatusMsg" class="alert d-none" role="alert"></div>

<div class="admin-card">
  <div class="admin-card-header d-flex flex-wrap align-items-center gap-2">
    <span>قائمة المندوبين</span>
    <button type="button" class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#agentModal" id="btnAddAgent">
      <i class="bi bi-plus-lg me-1"></i>إضافة مندوب
    </button>
    <button type="button" class="btn btn-outline-secondary btn-sm" id="btnRefreshAgents"><i class="bi bi-arrow-clockwise me-1"></i>تحديث</button>
  </div>
  <div class="admin-card-body p-0">
    <div class="table-responsive admin-mobile-cards">
      <table class="table table-hover table-sm align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th>#</th>
            <th>الاسم</th>
            <th>الهاتف</th>
            <th>البريد</th>
            <th class="text-center">الحالة</th>
            <th class="text-center">إجراءات</th>
          </tr>
        </thead>
        <tbody id="agentTblBody"></tbody>
      </table>
    </div>
  </div>
</div>

<!-- نافذة إضافة / تعديل مندوب -->
<div class="modal fade" id="agentModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="agentModalTitle">إضافة مندوب</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="إغلاق"></button>
      </div>
      <div class="modal-body">
        <input type="hidden" id="agentId" />
        <div class="row g-3">
          <div class="col-12">
            <label class="form-label">اسم المندوب</label>
            <input type="text" class="form-control" id="agentName" placeholder="اسم المندوب" required />
          </div>
          <div class="col-12">
            <label class="form-label">رقم الهاتف</label>
            <input type="text" class="form-control" id="agentPhone" placeholder="رقم الهاتف" required />
          </div>
          <div class="col-12">
            <label class="form-label">الرقم السري</label>
            <input type="text" class="form-control" id="agentPin" placeholder="الرقم السري لدخول تطبيق المندوب" required />
          </div>
          <div class="col-12">
            <label class="form-label">البريد الإلكتروني (اختياري)</label>
            <input type="email" class="form-control" id="agentEmail" placeholder="example@email.com" />
          </div>
          <div class="mb-3">
            <label class="form-label">نسبة العمولة للمتجر (%)</label>
            <input type="number" class="form-control" id="agentCommissionPercent" placeholder="10" min="0" max="100" step="0.1" value="0" />
          </div>
          <div class="col-12">
            <label class="form-label">الحالة</label>
            <select class="form-select" id="agentStatus">
              <option value="0">متاح</option>
              <option value="1">مشغول</option>
              <option value="2">غير متاح</option>
            </select>
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">إلغاء</button>
        <button type="button" class="btn btn-primary" id="agentSaveBtn">حفظ</button>
      </div>
    </div>
  </div>
</div>

@section Scripts {
<script>
(function(){
  const tbody = document.getElementById('agentTblBody');
  const modalEl = document.getElementById('agentModal');
  const modal = new bootstrap.Modal(modalEl);
  const modalTitle = document.getElementById('agentModalTitle');
  const statusMsg = document.getElementById('agentStatusMsg');

  function showStatus(text, isSuccess){
    if(!statusMsg) return;
    statusMsg.textContent = text;
    statusMsg.className = 'alert ' + (isSuccess ? 'alert-success' : 'alert-danger') + ' d-block';
    statusMsg.setAttribute('role', 'alert');
    setTimeout(function(){ statusMsg.classList.add('d-none'); }, 4000);
  }

  function statusText(s){ return ['متاح','مشغول','غير متاح'][s] || ''; }

  var lastAgents = [];
  async function load(){
    const res = await fetch('/api/admin/agents');
    if(!res.ok){ tbody.innerHTML = '<tr><td colspan="6">فشل التحميل. تحقق من صلاحيات الدخول.</td></tr>'; return; }
    const list = await res.json();
    lastAgents = list;
    tbody.innerHTML = list.length ? list.map(function(a){
      return '<tr><td data-label="#">' + a.id + '</td><td data-label="الاسم">' + escapeHtml(a.name || '') + '</td><td data-label="الهاتف">' + escapeHtml(a.phone || '') + '</td><td data-label="البريد">' + escapeHtml(a.email || '—') + '</td><td data-label="الحالة" class="text-center">' + statusText(a.status) + '</td><td class="text-end mobile-actions-cell" data-label="إجراءات"><button class="btn btn-sm btn-outline-primary me-1" onclick="window.editAgent(' + a.id + ')">تعديل</button><button class="btn btn-sm btn-outline-danger" onclick="window.deleteAgent(' + a.id + ')">حذف</button></td></tr>';
    }).join('') : '<tr><td colspan="6">لا يوجد مندوبون. اضغط «إضافة مندوب» للبدء.</td></tr>';
  }

  function escapeHtml(s){
    if(!s) return '';
    var div = document.createElement('div');
    div.textContent = s;
    return div.innerHTML;
  }

  function fillForm(a){
    document.getElementById('agentId').value = a ? a.id : '';
    document.getElementById('agentName').value = a ? a.name : '';
    document.getElementById('agentPhone').value = a ? a.phone : '';
    document.getElementById('agentPin').value = (a && a.pin) ? a.pin : '1234';
    if(document.getElementById('agentCommissionPercent')) document.getElementById('agentCommissionPercent').value = (a && a.commissionPercent != null) ? a.commissionPercent : 0;
    document.getElementById('agentEmail').value = (a && a.email) ? a.email : '';
    document.getElementById('agentStatus').value = a ? String(a.status) : '0';
    modalTitle.textContent = a ? 'تعديل مندوب' : 'إضافة مندوب';
  }

  window.editAgent = function(id){
    var a = lastAgents.find(function(x){ return x.id === id; });
    fillForm(a || null);
    modal.show();
  };

  window.deleteAgent = async function(id){
    if(!confirm('حذف المندوب رقم ' + id + '؟')) return;
    const res = await fetch('/api/admin/agents/' + id, { method: 'DELETE' });
    if(res.ok){ showStatus('تم حذف المندوب', true); load(); }
    else {
      var text = 'فشل حذف المندوب';
      try{ var j = await res.json(); if(j && j.message) text = j.message; }catch(_){}
      showStatus(text, false);
    }
  };

  document.getElementById('btnAddAgent').addEventListener('click', function(){ fillForm(null); });
  document.getElementById('btnRefreshAgents').addEventListener('click', load);

  document.getElementById('agentSaveBtn').addEventListener('click', async function(){
    var idEl = document.getElementById('agentId');
    var id = idEl.value ? parseInt(idEl.value, 10) : null;
    var name = document.getElementById('agentName').value.trim();
    var phone = document.getElementById('agentPhone').value.trim();
    var pin = document.getElementById('agentPin').value.trim();
    var email = document.getElementById("agentEmail").value.trim() || null;
    var commissionPercent = parseFloat(document.getElementById("agentCommissionPercent")?.value || "0");
    if(!name){ showStatus('أدخل اسم المندوب', false); return; }
    if(!phone){ showStatus('أدخل رقم الهاتف', false); return; }
    if(!pin){ showStatus('أدخل الرقم السري', false); return; }
    var payload = {
      id: id,
      name: name,
      phone: phone,
      pin: pin,
      commissionPercent: commissionPercent,
      email: email,
      status: parseInt(document.getElementById('agentStatus').value, 10),
      photoUrl: null
    };
    var res = await fetch('/api/admin/agents', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) });
    if(res.ok){
      showStatus('تم الحفظ', true);
      modal.hide();
      load();
    } else {
      var text = 'فشل الحفظ';
      try{ var j = await res.json(); if(j && j.message) text = j.message; }catch(_){}
      showStatus(text, false);
    }
  });

  modalEl.addEventListener('hidden.bs.modal', function(){ fillForm(null); });

  load();
})();
</script>
}
