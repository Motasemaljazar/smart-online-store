@page
@model AdminDashboard.Pages.Admin.AdminPageModel
@{
    ViewData["Title"] = "السائقون";
}

<div class="admin-page-header">
  <div class="page-icon"><i class="bi bi-people"></i></div>
  <div>
    <h1 class="page-title">إدارة السائقين</h1>
    <p class="page-subtitle">إضافة وتعديل السائقين والمركبات</p>
  </div>
</div>

<div id="driverStatusMsg" class="alert d-none" role="alert"></div>

<div class="admin-card">
  <div class="admin-card-header d-flex flex-wrap align-items-center gap-2">
    <span>قائمة السائقين</span>
    <button type="button" class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#driverModal" id="btnAddDriver">
      <i class="bi bi-plus-lg me-1"></i>إضافة سائق
    </button>
    <button type="button" class="btn btn-outline-secondary btn-sm" id="btnRefreshDrivers"><i class="bi bi-arrow-clockwise me-1"></i>تحديث</button>
  </div>
  <div class="admin-card-body p-0">
    <div class="table-responsive admin-mobile-cards">
      <table class="table table-hover table-sm align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th>#</th>
            <th>الاسم</th>
            <th>الهاتف</th>
            <th>المركبة</th>
            <th class="text-center">الحالة</th>
            <th class="text-center">إجراءات</th>
          </tr>
        </thead>
        <tbody id="driverTblBody"></tbody>
      </table>
    </div>
  </div>
</div>

<!-- نافذة إضافة / تعديل سائق -->
<div class="modal fade" id="driverModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="driverModalTitle">إضافة سائق</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="إغلاق"></button>
      </div>
      <div class="modal-body">
        <input type="hidden" id="driverId" />
        <div class="row g-3">
          <div class="col-12">
            <label class="form-label">اسم السائق</label>
            <input type="text" class="form-control" id="driverName" placeholder="اسم السائق" required />
          </div>
          <div class="col-12">
            <label class="form-label">رقم الهاتف</label>
            <input type="text" class="form-control" id="driverPhone" placeholder="رقم الهاتف" required />
          </div>
          <div class="col-12">
            <label class="form-label">الرقم السري</label>
            <input type="text" class="form-control" id="driverPin" placeholder="الرقم السري لدخول تطبيق السائق" required />
          </div>
          <div class="col-12">
            <label class="form-label">نوع المركبة</label>
            <select class="form-select" id="driverVehicleType">
              <option value="0">دراجة</option>
              <option value="1">سيارة</option>
            </select>
          </div>
          <div class="col-12">
            <label class="form-label">الحالة</label>
            <select class="form-select" id="driverStatus">
              <option value="0">متاح</option>
              <option value="1">مشغول</option>
              <option value="2">غير متاح</option>
            </select>
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">إلغاء</button>
        <button type="button" class="btn btn-primary" id="driverSaveBtn">حفظ</button>
      </div>
    </div>
  </div>
</div>

@section Scripts {
<script>
(function(){
  const tbody = document.getElementById('driverTblBody');
  const modalEl = document.getElementById('driverModal');
  const modal = new bootstrap.Modal(modalEl);
  const modalTitle = document.getElementById('driverModalTitle');
  const statusMsg = document.getElementById('driverStatusMsg');

  function showStatus(text, isSuccess){
    if(!statusMsg) return;
    statusMsg.textContent = text;
    statusMsg.className = 'alert ' + (isSuccess ? 'alert-success' : 'alert-danger') + ' d-block';
    statusMsg.setAttribute('role', 'alert');
    setTimeout(function(){ statusMsg.classList.add('d-none'); }, 4000);
  }

  function vehicleText(v){ return v === 0 ? 'دراجة' : 'سيارة'; }
  function statusText(s){ return ['متاح','مشغول','غير متاح'][s] || ''; }

  var lastDrivers = [];
  async function load(){
    const res = await fetch('/api/admin/drivers');
    if(!res.ok){ tbody.innerHTML = '<tr><td colspan="6">فشل التحميل. تحقق من صلاحيات الدخول.</td></tr>'; return; }
    const list = await res.json();
    lastDrivers = list;
    tbody.innerHTML = list.length ? list.map(function(d){
      return '<tr><td data-label="#">' + d.id + '</td><td data-label="الاسم">' + escapeHtml(d.name || '') + '</td><td data-label="الهاتف">' + escapeHtml(d.phone || '') + '</td><td data-label="المركبة">' + vehicleText(d.vehicleType) + '</td><td data-label="الحالة" class="text-center">' + statusText(d.status) + '</td><td class="text-end mobile-actions-cell" data-label="إجراءات"><button class="btn btn-sm btn-outline-primary me-1" onclick="window.editDriver(' + d.id + ')">تعديل</button><button class="btn btn-sm btn-outline-danger" onclick="window.deleteDriver(' + d.id + ')">حذف</button></td></tr>';
    }).join('') : '<tr><td colspan="6">لا يوجد سائقون. اضغط «إضافة سائق» للبدء.</td></tr>';
  }

  function escapeHtml(s){
    if(!s) return '';
    var div = document.createElement('div');
    div.textContent = s;
    return div.innerHTML;
  }

  function fillForm(d){
    document.getElementById('driverId').value = d ? d.id : '';
    document.getElementById('driverName').value = d ? d.name : '';
    document.getElementById('driverPhone').value = d ? d.phone : '';
    document.getElementById('driverPin').value = (d && d.pin) ? d.pin : '1234';
    document.getElementById('driverVehicleType').value = d ? String(d.vehicleType) : '0';
    document.getElementById('driverStatus').value = d ? String(d.status) : '0';
    modalTitle.textContent = d ? 'تعديل سائق' : 'إضافة سائق';
  }

  window.editDriver = function(id){
    var d = lastDrivers.find(function(x){ return x.id === id; });
    fillForm(d || null);
    modal.show();
  };

  window.deleteDriver = async function(id){
    if(!confirm('حذف السائق رقم ' + id + '؟')) return;
    const res = await fetch('/api/admin/drivers/' + id, { method: 'DELETE' });
    if(res.ok){ showStatus('تم حذف السائق', true); load(); }
    else {
      var text = 'فشل حذف السائق';
      try{ var j = await res.json(); if(j && j.message) text = j.message; }catch(_){}
      showStatus(text, false);
    }
  };

  document.getElementById('btnAddDriver').addEventListener('click', function(){ fillForm(null); });
  document.getElementById('btnRefreshDrivers').addEventListener('click', load);

  document.getElementById('driverSaveBtn').addEventListener('click', async function(){
    var idEl = document.getElementById('driverId');
    var id = idEl.value ? parseInt(idEl.value, 10) : null;
    var name = document.getElementById('driverName').value.trim();
    var phone = document.getElementById('driverPhone').value.trim();
    var pin = document.getElementById('driverPin').value.trim();
    if(!name){ showStatus('أدخل اسم السائق', false); return; }
    if(!phone){ showStatus('أدخل رقم الهاتف', false); return; }
    if(!pin){ showStatus('أدخل الرقم السري', false); return; }
    var payload = {
      id: id,
      name: name,
      phone: phone,
      pin: pin,
      vehicleType: parseInt(document.getElementById('driverVehicleType').value, 10),
      status: parseInt(document.getElementById('driverStatus').value, 10),
      photoUrl: null
    };
    var res = await fetch('/api/admin/drivers', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) });
    if(res.ok){
      showStatus('تم الحفظ', true);
      modal.hide();
      load();
    } else {
      showStatus('فشل الحفظ', false);
    }
  });

  modalEl.addEventListener('hidden.bs.modal', function(){ fillForm(null); });

  load();
})();
</script>
}
