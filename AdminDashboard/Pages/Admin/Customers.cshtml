@page
@model AdminDashboard.Pages.Admin.AdminPageModel
@{
    ViewData["Title"] = "الزبائن";
}

<div class="admin-page-header">
  <div class="page-icon"><i class="bi bi-people"></i></div>
  <div>
    <h1 class="page-title">إدارة الزبائن</h1>
    <p class="page-subtitle">بيانات الزبائن والطلبات والتواصل</p>
  </div>
</div>

<div class="admin-card">
  <div class="admin-card-header d-flex flex-wrap align-items-center justify-content-between gap-2">
    <span>قائمة الزبائن</span>
    <div class="d-flex align-items-center gap-2">
      <input type="text" id="customerSearch" class="form-control form-control-sm" style="width:220px" placeholder="بحث بالاسم أو رقم الهاتف..." />
      <button type="button" class="btn btn-sm btn-primary" id="customerSearchBtn"><i class="bi bi-search me-1"></i>بحث</button>
    </div>
  </div>
  <div class="admin-card-body p-0">
    <div class="table-responsive customers-table-responsive">
      <table class="table table-hover align-middle mb-0 customers-data-table">
        <thead class="table-light">
          <tr>
            <th>#</th>
            <th>الاسم</th>
            <th>الهاتف</th>
            <th>البريد</th>
            <th>العنوان</th>
            <th class="text-center">الموقع</th>
            <th class="text-center">تواصل</th>
            <th class="text-center">تفاصيل</th>
            <th class="text-center">الحالة</th>
            <th class="text-center">حذف</th>
            <th>التاريخ</th>
          </tr>
        </thead>
        <tbody id="rows"></tbody>
      </table>
    </div>
  </div>
</div>

<!-- Details Modal (Orders + Ratings) -->
<div class="modal fade" id="custDetailsModal" tabindex="-1">
  <div class="modal-dialog modal-xl modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="custDetailsTitle">تفاصيل الزبون</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div class="d-flex flex-wrap gap-2 mb-3" id="custDetailsHeader"></div>
        <div id="custOrders"></div>
      </div>
    </div>
  </div>
</div>

<!-- Map Modal -->
<div class="modal fade" id="custMapModal" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="custMapTitle">موقع الزبون</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div id="custMap" style="height:420px;border-radius:14px;overflow:hidden"></div>
        <div class="small text-muted mt-2" id="custMapHint"></div>
      </div>
    </div>
  </div>
</div>

<!-- تواصل (Contact) Popup -->
<div class="modal fade" id="custContactModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered modal-sm">
    <div class="modal-content">
      <div class="modal-header py-2">
        <h6 class="modal-title"><i class="bi bi-chat-dots me-2"></i>تواصل</h6>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body p-2" id="custContactModalBody">
        <!-- يُملأ ديناميكياً -->
      </div>
    </div>
  </div>
</div>

@section Scripts {
<script>
let detailsModal=null;
let mapModal=null;
let contactModal=null;
let map=null;
let marker=null;

const customersById = {};

function esc(s){
  return (s??'').toString()
    .replaceAll('&','&amp;')
    .replaceAll('<','&lt;')
    .replaceAll('>','&gt;')
    .replaceAll('"','&quot;')
    .replaceAll("'",'&#39;');
}

function fmtUtc(dt){
  return (dt||'').toString().replace('T',' ');
}

function stars(v){
  const n = Math.max(0, Math.min(5, Number(v||0)));
  const full = '★'.repeat(n);
  const empty = '☆'.repeat(5-n);
  return `<span style="letter-spacing:1px;color:#f2b01e">${full}</span><span style="letter-spacing:1px;color:#bbb">${empty}</span>`;
}

async function openCustomerDetailsById(id){
  const c = customersById[id];
  if(!c) return;
  document.getElementById('custDetailsTitle').innerText = `تفاصيل الزبون: ${c.name||''} (#${c.id})`;
  const header = document.getElementById('custDetailsHeader');
  header.innerHTML = `
    <span class="badge text-bg-light border">هاتف: ${esc(c.phone||'—')}</span>
    <span class="badge text-bg-light border">بريد: ${esc(c.email||'—')}</span>
    <span class="badge text-bg-light border">إنشاء: ${esc(fmtUtc(c.createdAtUtc))}</span>
    ${c.isChatBlocked ? '<span class="badge text-bg-warning">الدردشة موقوفة</span>' : ''}
    <a class="btn btn-sm btn-outline-dark" href="/Admin/Chats?customerId=${c.id}">فتح الدردشة</a>
  `;
  const container = document.getElementById('custOrders');
  container.innerHTML = '<div class="text-muted">جاري تحميل الطلبات…</div>';
  detailsModal.show();

  try{
    const res = await fetch(`/api/admin/customers/${id}/details`);
    if(!res.ok) throw new Error('فشل التحميل');
    const json = await res.json();
    const orders = json.orders || [];
    if(orders.length === 0){
      container.innerHTML = '<div class="alert alert-light border">لا يوجد طلبات لهذا الزبون.</div>';
      return;
    }
    container.innerHTML = '';
    for(const o of orders){
      // التقييمات تُعرض في صفحة التقييمات المخصصة فقط
      const ratingHtml = '';

      const items = Array.isArray(o.items) ? o.items : [];
      const itemsRows = items.map(i => {
        // Parse options if they're JSON
        let optionsText = '';
        try {
          if (i.options && i.options.trim().startsWith('{')) {
            const opts = JSON.parse(i.options);
            if (opts.offerVariantId) optionsText += 'خيار محدد • ';
            if (opts.offerAddonIds && opts.offerAddonIds.length > 0) optionsText += `${opts.offerAddonIds.length} إضافة • `;
            if (opts.note) optionsText += `ملاحظة: ${opts.note}`;
            optionsText = optionsText.replace(/ • $/, '').trim() || 'لا توجد خيارات';
          } else {
            optionsText = i.options || 'لا توجد خيارات';
          }
        } catch {
          optionsText = i.options ? 'خيارات مخصصة' : 'لا توجد خيارات';
        }
        
        return `
        <tr>
          <td><span class="fw-semibold">${esc(i.name)}</span></td>
          <td class="text-center"><span class="badge bg-primary">${esc(i.qty)}</span></td>
          <td class="text-end fw-bold">${Number(i.unit||0).toFixed(2)} ل.س</td>
          <td class="small text-muted">${esc(optionsText)}</td>
        </tr>
      `}).join('');

      const card = document.createElement('div');
      card.className = 'card mb-3';
      card.innerHTML = `
        <div class="card-body">
          <div class="d-flex flex-wrap justify-content-between align-items-center gap-2">
            <div>
              <div class="fw-bold">طلب #${o.id}</div>
              <div class="small text-muted">${esc(o.status)} • ${esc(fmtUtc(o.createdAtUtc))}</div>
            </div>
            <div class="text-end">
              <div class="fw-bold">الإجمالي: ${Number(o.total||0).toFixed(2)}</div>
              <div class="small text-muted">الخصم: ${Number(o.cartDiscount||0).toFixed(2)}</div>
            </div>
          </div>

          <div class="mt-2">
            <div class="small text-muted">العنوان:</div>
            <div>${esc(o.deliveryAddress||'—')}</div>
          </div>

          <div class="table-responsive mt-3">
            <table class="table table-sm table-striped align-middle">
              <thead>
                <tr>
                  <th>الصنف</th>
                  <th class="text-center" style="width:90px">الكمية</th>
                  <th class="text-end" style="width:120px">السعر</th>
                  <th>الخيارات</th>
                </tr>
              </thead>
              <tbody>
                ${itemsRows || `<tr><td colspan="4" class="text-muted">لا يوجد تفاصيل عناصر.</td></tr>`}
              </tbody>
            </table>
          </div>

          ${ratingHtml}
        </div>
      `;
      container.appendChild(card);
    }
  }catch(e){
    container.innerHTML = '<div class="alert alert-danger">تعذر تحميل تفاصيل الزبون.</div>';
  }
}

function openCustomerMapById(id){
  const c = customersById[id];
  if(!c) return;
  openCustomerMap(c);
}

function openCustomerMap(c){
  const title = document.getElementById('custMapTitle');
  const hint = document.getElementById('custMapHint');
  title.innerText = `موقع الزبون: ${c.name || ''} (#${c.id})`;

  const lat = (c.lastLat && c.lastLat !== 0) ? c.lastLat : c.defaultLat;
  const lng = (c.lastLng && c.lastLng !== 0) ? c.lastLng : c.defaultLng;

  if(!lat || !lng || lat === 0 || lng === 0){
    hint.innerText = 'لا يوجد إحداثيات محفوظة لهذا الزبون حالياً.';
  } else {
    hint.innerText = `خط العرض: ${lat}، خط الطول: ${lng}`;
  }

  mapModal.show();
  setTimeout(()=>{
    if(!map){
      map = L.map('custMap');
      L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png', { maxZoom: 19 }).addTo(map);
    }
    map.invalidateSize();
    if(lat && lng && lat!==0 && lng!==0){
      map.setView([lat, lng], 16);
      if(marker) marker.remove();
      marker = L.marker([lat, lng]).addTo(map);
    }
  }, 250);
}

function telLink(phone){
  const p = (phone||'').toString().replace(/\s+/g,'');
  return p ? `tel:${p}` : '#';
}

function waLink(phone){
  const p = (phone||'').toString().replace(/\s+/g,'');
  if(!p) return '#';
  // WhatsApp click-to-chat (web). Phone should be in international format when possible.
  return `https://wa.me/${p.replace(/^\+/, '')}`;
}

async function load(){
  const searchInput = document.getElementById('customerSearch');
  const search = (searchInput && searchInput.value) ? searchInput.value.trim() : '';
  const url = search ? '/api/admin/customers?search=' + encodeURIComponent(search) : '/api/admin/customers';
  const res = await fetch(url);
  const json = await res.json();
  const rows = document.getElementById('rows');
  rows.innerHTML = '';
  for(const c of (json.customers||[])){
    customersById[c.id] = c;
    const tr = document.createElement('tr');
    const hasPos = (c.lastLat && c.lastLng && c.lastLat!==0 && c.lastLng!==0) || (c.defaultLat && c.defaultLng && c.defaultLat!==0 && c.defaultLng!==0);
    const mapBtn = hasPos ? `<button class="btn btn-sm btn-outline-primary" onclick='openCustomerMapById(${c.id})'>خريطة</button>` : `<span class="text-muted small">—</span>`;
    const phone = (c.phone||'').toString();
    const chatBadge = c.isChatBlocked ? `<span class="badge text-bg-warning">الدردشة موقوفة</span>` : '';
    const appBadge = c.isAppBlocked ? `<span class="badge text-bg-danger">ممنوع من الدخول</span>` : '';
    const contactBtn = phone ? `<button class="btn btn-sm btn-outline-primary" type="button" onclick="openContactPopup(${c.id}, '${String(phone).replace(/'/g, "\\'")}')" title="تواصل"><i class="bi bi-chat-dots me-1"></i>تواصل</button>${chatBadge}${appBadge}` : `<span class="text-muted small">—</span>`;

    const stopBtnText = c.isAppBlocked ? 'إلغاء الإيقاف' : 'إيقاف';
    const stopBtnClass = c.isAppBlocked ? 'btn-outline-secondary' : 'btn-outline-danger';
    const escAttr = (s) => (s||'').toString().replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    tr.innerHTML = `
      <td data-label="#">${c.id}</td>
      <td class="cust-cell-text" data-label="الاسم" title="${escAttr(c.name)}">${esc(c.name||'')}</td>
      <td class="cust-cell-text" data-label="الهاتف" title="${escAttr(phone)}">${phone}</td>
      <td class="cust-cell-text" data-label="البريد" title="${escAttr(c.email)}">${esc(c.email||'')}</td>
      <td class="cust-cell-text" data-label="العنوان" title="${escAttr(c.defaultAddress)}">${esc(c.defaultAddress||'')}</td>
      <td class="text-center" data-label="الموقع">${mapBtn}</td>
      <td class="text-center cust-contact-cell" data-label="تواصل">${contactBtn}</td>
      <td class="text-center" data-label="تفاصيل"><button class="btn btn-sm btn-primary" onclick="openCustomerDetailsById(${c.id})">تفاصيل</button></td>
      <td class="text-center" data-label="الحالة"><button class="btn btn-sm ${stopBtnClass}" onclick="toggleAppBlock(${c.id})">${stopBtnText}</button></td>
      <td class="text-center" data-label="حذف"><button class="btn btn-sm btn-outline-danger" onclick="deleteCustomer(${c.id})" title="حذف حساب الزبون">حذف</button></td>
      <td class="small" data-label="التاريخ">${fmtUtc(c.createdAtUtc)}</td>`;
    rows.appendChild(tr);
  }
}

async function toggleAppBlock(customerId){
  const c = customersById[customerId];
  if(!c) return;
  const next = !Boolean(c.isAppBlocked);
  const ok = confirm(next ? 'هل تريد منع هذا الزبون من الدخول إلى التطبيق؟' : 'هل تريد إلغاء منع هذا الزبون؟');
  if(!ok) return;
  try{
    const res = await fetch(`/api/admin/customers/${customerId}/app-block`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ blocked: next })
    });
    if(!res.ok) throw new Error('فشل التحميل');
    c.isAppBlocked = next;
    await load();
  }catch(e){
    alert('تعذر تحديث حالة الإيقاف.');
  }
}

async function deleteCustomer(customerId){
  const c = customersById[customerId];
  if(!c) return;
  const ok = confirm('هل أنت متأكد من حذف حساب الزبون "' + (c.name || '#' + customerId) + '"؟ سيتم حذف كل الطلبات والعناوين والدردشات المرتبطة به نهائياً.');
  if(!ok) return;
  try{
    const res = await fetch('/api/admin/customers/' + customerId, { method: 'DELETE' });
    if(!res.ok) throw new Error('فشل التحميل');
    delete customersById[customerId];
    await load();
  }catch(e){
    alert('تعذر حذف الزبون.');
  }
}
function openContactPopup(customerId, phone){
  const body = document.getElementById('custContactModalBody');
  const wa = (waLink(phone) || '').replace(/"/g, '&quot;');
  const tel = (telLink(phone) || '').replace(/"/g, '&quot;');
  body.innerHTML = `
    <div class="d-grid gap-1">
      <a class="btn btn-sm btn-outline-success text-start" target="_blank" rel="noopener" href="${wa}" role="button"><i class="bi bi-whatsapp me-2"></i>واتساب</a>
      <a class="btn btn-sm btn-outline-primary text-start" href="${tel}" role="button"><i class="bi bi-telephone me-2"></i>اتصال</a>
      <a class="btn btn-sm btn-outline-secondary text-start" href="/Admin/Chats?customerId=${customerId}" role="button"><i class="bi bi-chat me-2"></i>دردشة</a>
    </div>`;
  if(!contactModal) contactModal = new bootstrap.Modal(document.getElementById('custContactModal'));
  contactModal.show();
}

document.addEventListener('DOMContentLoaded', ()=>{
  detailsModal = new bootstrap.Modal(document.getElementById('custDetailsModal'));
  mapModal = new bootstrap.Modal(document.getElementById('custMapModal'));
  load();

  const searchInput = document.getElementById('customerSearch');
  const searchBtn = document.getElementById('customerSearchBtn');
  if (searchBtn) searchBtn.addEventListener('click', function(){ load(); });
  if (searchInput) {
    searchInput.addEventListener('keydown', function(e){ if (e.key === 'Enter') load(); });
  }
});
</script>
}
