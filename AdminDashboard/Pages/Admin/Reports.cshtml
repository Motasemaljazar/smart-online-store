@page
@model AdminDashboard.Pages.Admin.AdminPageModel
@{
    ViewData["Title"] = "التقارير";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <h2 class="h5 m-0 fw-bold" style="color:#fff">&#x1F4CA; التقارير والإحصائيات</h2>
    <button class="btn btn-sm btn-outline-light" onclick="loadAll()">تحديث</button>
</div>

<ul class="nav nav-pills mb-4" role="tablist">
    <li class="nav-item"><button class="nav-link active" data-bs-toggle="pill" data-bs-target="#pane-today" type="button">اليوم</button></li>
    <li class="nav-item"><button class="nav-link" data-bs-toggle="pill" data-bs-target="#pane-week" type="button">الأسبوع</button></li>
    <li class="nav-item"><button class="nav-link" data-bs-toggle="pill" data-bs-target="#pane-month" type="button">الشهر</button></li>
</ul>

<div class="tab-content">

    <!-- اليوم -->
    <div class="tab-pane fade show active" id="pane-today" role="tabpanel">
        <div class="row g-3 mb-4" id="cardsToday"></div>
        <div class="card border-0 shadow-sm rounded-4 mb-4" style="background:rgba(255,255,255,0.07)">
            <div class="card-header bg-transparent border-0"><h6 class="m-0 fw-bold" style="color:#fff">&#x1F3C6; أفضل المنتجات اليوم</h6></div>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead style="background:rgba(255,255,255,0.1)"><tr><th style="color:#ffd700">المنتج</th><th style="color:#ffd700">الكمية</th><th style="color:#ffd700">الإيراد</th></tr></thead>
                    <tbody id="tbProductsToday"><tr><td colspan="3" class="text-center py-3" style="color:#ccc">جاري التحميل...</td></tr></tbody>
                </table>
            </div>
        </div>
        <div class="card border-0 shadow-sm rounded-4 mb-4" style="background:rgba(255,255,255,0.07)">
            <div class="card-header bg-transparent border-0"><h6 class="m-0 fw-bold" style="color:#fff">&#x1F464; عمولات المندوبين اليوم</h6></div>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead style="background:rgba(255,255,255,0.1)"><tr><th style="color:#ffd700">المندوب</th><th style="color:#ffd700">الطلبات</th><th style="color:#ffd700">المبيعات</th><th style="color:#ffd700">العمولة</th></tr></thead>
                    <tbody id="tbAgentsToday"><tr><td colspan="4" class="text-center py-3" style="color:#ccc">جاري التحميل...</td></tr></tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- الأسبوع -->
    <div class="tab-pane fade" id="pane-week" role="tabpanel">
        <div class="row g-3 mb-4" id="cardsWeek"></div>
        <div class="card border-0 shadow-sm rounded-4 mb-4" style="background:rgba(255,255,255,0.07)">
            <div class="card-header bg-transparent border-0"><h6 class="m-0 fw-bold" style="color:#fff">&#x1F3C6; أفضل المنتجات (الأسبوع)</h6></div>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead style="background:rgba(255,255,255,0.1)"><tr><th style="color:#ffd700">المنتج</th><th style="color:#ffd700">الكمية</th><th style="color:#ffd700">الإيراد</th></tr></thead>
                    <tbody id="tbProductsWeek"><tr><td colspan="3" class="text-center py-3" style="color:#ccc">جاري التحميل...</td></tr></tbody>
                </table>
            </div>
        </div>
        <div class="card border-0 shadow-sm rounded-4 mb-4" style="background:rgba(255,255,255,0.07)">
            <div class="card-header bg-transparent border-0"><h6 class="m-0 fw-bold" style="color:#fff">&#x1F464; عمولات المندوبين (الأسبوع)</h6></div>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead style="background:rgba(255,255,255,0.1)"><tr><th style="color:#ffd700">المندوب</th><th style="color:#ffd700">الطلبات</th><th style="color:#ffd700">المبيعات</th><th style="color:#ffd700">العمولة</th></tr></thead>
                    <tbody id="tbAgentsWeek"><tr><td colspan="4" class="text-center py-3" style="color:#ccc">جاري التحميل...</td></tr></tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- الشهر -->
    <div class="tab-pane fade" id="pane-month" role="tabpanel">
        <div class="row g-3 mb-4" id="cardsMonth"></div>
        <div class="card border-0 shadow-sm rounded-4 mb-4" style="background:rgba(255,255,255,0.07)">
            <div class="card-header bg-transparent border-0"><h6 class="m-0 fw-bold" style="color:#fff">&#x1F3C6; أفضل المنتجات (الشهر)</h6></div>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead style="background:rgba(255,255,255,0.1)"><tr><th style="color:#ffd700">المنتج</th><th style="color:#ffd700">الكمية</th><th style="color:#ffd700">الإيراد</th></tr></thead>
                    <tbody id="tbProductsMonth"><tr><td colspan="3" class="text-center py-3" style="color:#ccc">جاري التحميل...</td></tr></tbody>
                </table>
            </div>
        </div>
        <div class="card border-0 shadow-sm rounded-4 mb-4" style="background:rgba(255,255,255,0.07)">
            <div class="card-header bg-transparent border-0"><h6 class="m-0 fw-bold" style="color:#fff">&#x1F464; عمولات المندوبين (الشهر)</h6></div>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead style="background:rgba(255,255,255,0.1)"><tr><th style="color:#ffd700">المندوب</th><th style="color:#ffd700">الطلبات</th><th style="color:#ffd700">المبيعات</th><th style="color:#ffd700">العمولة</th></tr></thead>
                    <tbody id="tbAgentsMonth"><tr><td colspan="4" class="text-center py-3" style="color:#ccc">جاري التحميل...</td></tr></tbody>
                </table>
            </div>
        </div>
    </div>

</div>

@section Scripts {
    <script>
        const f2  = n => (isNaN(+n)||n==null) ? '0.00' : (+n).toFixed(2);
        const esc = s => (s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
        const none = cols => '<tr><td colspan="'+cols+'" class="text-center py-3" style="color:#ccc">لا توجد بيانات</td></tr>';

        function renderCards(elId, d){
          const el = document.getElementById(elId);
          if(!el) return;
          const sales  = f2(d.salesToday  ?? d.sales ?? 0);
          const orders = d.ordersCount ?? 0;
          const profit = f2(d.storeProfitToday ?? d.storeProfit ?? 0);
          const agComm = f2(d.agentCommTotalToday ?? d.agentCommissionsTotal ?? 0);
          el.innerHTML =
            card('إجمالي المبيعات',  sales,   '#4ade80') +
            card('عدد الطلبات',      orders,  '#60a5fa') +
            card('ربح المتجر',        profit,  '#38bdf8') +
            card('عمولات المندوبين', agComm,  '#f87171');
        }

        function card(label, val, color){
          return '<div class="col-6 col-md-3"><div class="rounded-4 p-3" style="background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.12)">'+
            '<div class="small mb-1" style="color:#ccc">'+label+'</div>'+
            '<div class="fs-5 fw-bold" style="color:'+color+'">'+val+'</div>'+
            '</div></div>';
        }

        function renderProducts(elId, arr){
          const el = document.getElementById(elId);
          if(!el) return;
          if(!arr||arr.length===0){ el.innerHTML=none(3); return; }
          el.innerHTML = arr.map(r =>
            '<tr style="color:#fff"><td>'+esc(r.name||'—')+'</td><td>'+(r.qty||0)+'</td><td style="color:#4ade80;font-weight:600">'+f2(r.revenue)+'</td></tr>'
          ).join('');
        }

        function renderAgents(elId, arr){
          const el = document.getElementById(elId);
          if(!el) return;
          if(!arr||arr.length===0){ el.innerHTML=none(4); return; }
          el.innerHTML = arr.map(r =>
            '<tr style="color:#fff"><td>'+esc(r.agentName||'—')+'</td>'+
            '<td>'+(r.orderCount||0)+'</td>'+
            '<td style="color:#4ade80;font-weight:600">'+f2(r.totalSales||0)+'</td>'+
            '<td style="color:#f87171;font-weight:700">'+f2(r.totalCommission||0)+'</td>'+
            '</tr>'
          ).join('');
        }

        async function loadAll(){
          try {
            const today = await fetch('/api/admin/reports/summary').then(r=>r.json()).catch(()=>({}));
            if(today.error) console.error('Reports summary error:', today.error);
            renderCards('cardsToday', today);
            renderProducts('tbProductsToday', today.topProducts ?? []);
            renderAgents('tbAgentsToday', today.agentCommissions ?? []);

            const week = await fetch('/api/admin/reports/weekly-summary').then(r=>r.json()).catch(()=>({}));
            if(week.error) console.error('Reports weekly error:', week.error);
            renderCards('cardsWeek', week);
            renderProducts('tbProductsWeek', week.topProducts ?? []);
            renderAgents('tbAgentsWeek', week.agentCommissions ?? []);

            const month = await fetch('/api/admin/reports/monthly-summary').then(r=>r.json()).catch(()=>({}));
            if(month.error) console.error('Reports monthly error:', month.error);
            renderCards('cardsMonth', month);
            renderProducts('tbProductsMonth', month.topProducts ?? []);
            renderAgents('tbAgentsMonth', month.agentCommissions ?? []);

          } catch(e){
            console.error('Reports error:', e);
          }
        }

        loadAll();
    </script>
}
