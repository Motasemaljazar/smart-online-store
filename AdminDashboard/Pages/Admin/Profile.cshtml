@page
@model AdminDashboard.Pages.Admin.ProfileModel

<h2 class="h5 mb-3">حساب الإدارة</h2>

@if (!string.IsNullOrWhiteSpace(Model.Status))
{
  <div class="alert alert-info">@Model.Status</div>
}

<form method="post" class="card p-3 rounded-4">
  <div class="mb-3">
    <label class="form-label">البريد/المستخدم</label>
    <input class="form-control" name="Email" value="@Model.Email" required />
  </div>
  <div class="mb-3">
    <label class="form-label">كلمة المرور الجديدة (اختياري)</label>
    <input class="form-control" type="password" name="NewPassword" />
  </div>
  <button class="btn btn-primary">حفظ</button>
</form>
