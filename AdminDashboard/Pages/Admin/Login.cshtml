@page
@model AdminDashboard.Pages.Admin.LoginModel
@{
    Layout = null;
    var logo = string.IsNullOrWhiteSpace(Model.LogoUrl) ? null : Model.LogoUrl;
    var title = string.IsNullOrWhiteSpace(Model.StoreName) ? "لوحة التحكم" : Model.StoreName;
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>تسجيل الدخول — لوحة التحكم</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.rtl.min.css" rel="stylesheet" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        :root {
            --gold: #D4AF37;
            --gold-light: #EDD97A;
            --gold-dark: #A88A1A;
            --purple: #7B2FBE;
            --purple-light: #9D55D4;
            --purple-dark: #4A1080;
            --bg-base: #1E1E2A;
            --bg-card: #252535;
            --bg-input: #1C1C28;
            --border: rgba(255,255,255,0.07);
            --border-gold: rgba(212,175,55,0.3);
            --text-primary: #EEEEF8;
            --text-secondary: #9898BC;
            --text-muted: #5A5A78;
        }

        *, *::before, *::after {
            box-sizing: border-box;
        }

        html, body {
            height: 100%;
            font-family: 'Cairo', system-ui, sans-serif;
            background-color: var(--bg-base);
            color: var(--text-primary);
        }

            /* خلفية ديكورية */
            body::before {
                content: "";
                position: fixed;
                inset: 0;
                z-index: 0;
                pointer-events: none;
                background: radial-gradient(800px 500px at 15% 10%, rgba(123,47,190,0.14), transparent 60%), radial-gradient(700px 500px at 85% 85%, rgba(212,175,55,0.10), transparent 60%), radial-gradient(500px 400px at 80% 10%, rgba(157,85,212,0.08), transparent 55%);
            }

            /* شبكة خلفية خفيفة */
            body::after {
                content: "";
                position: fixed;
                inset: 0;
                z-index: 0;
                pointer-events: none;
                background-image: linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
                background-size: 48px 48px;
            }

        .login-wrap {
            position: relative;
            z-index: 1;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem 1rem;
        }

        .login-card {
            width: 100%;
            max-width: 460px;
            background: var(--bg-card);
            border: 1px solid var(--border-gold);
            border-radius: 24px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.5), 0 0 0 1px rgba(212,175,55,0.08), 0 0 80px rgba(123,47,190,0.12);
            overflow: hidden;
            animation: slideUp 0.5s cubic-bezier(0.16,1,0.3,1) both;
        }

        @@keyframes slideUp {
            from {
                opacity: 0;
                transform: translateY(24px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* الجزء العلوي من البطاقة */
        .card-top {
            padding: 32px 28px 24px;
            background: linear-gradient(135deg, rgba(123,47,190,0.12), rgba(212,175,55,0.08));
            border-bottom: 1px solid var(--border-gold);
            text-align: center;
        }

        /* الشعار */
        .brand-logo {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--purple-dark), var(--purple));
            border: 1.5px solid var(--border-gold);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 12px 36px rgba(123,47,190,0.35), 0 0 0 6px rgba(212,175,55,0.08);
            margin-bottom: 16px;
            overflow: hidden;
        }

            .brand-logo img {
                width: 100%;
                height: 100%;
                object-fit: cover;
                border-radius: 50%;
            }

            .brand-logo .logo-icon {
                font-size: 2rem;
                color: var(--gold);
            }

        .brand-title {
            font-weight: 900;
            font-size: 1.4rem;
            margin: 0 0 6px;
            background: linear-gradient(135deg, var(--text-primary), var(--gold-light));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .brand-sub {
            font-size: 0.85rem;
            color: var(--text-secondary);
            margin: 0;
        }

        /* الفاصل الذهبي */
        .gold-divider {
            display: flex;
            align-items: center;
            gap: 10px;
            margin: 20px 0;
        }

            .gold-divider::before, .gold-divider::after {
                content: "";
                flex: 1;
                height: 1px;
                background: linear-gradient(90deg, transparent, var(--gold), transparent);
                opacity: 0.4;
            }

            .gold-divider span {
                width: 6px;
                height: 6px;
                border-radius: 50%;
                background: var(--gold);
                opacity: 0.7;
            }

        /* جسم البطاقة */
        .card-body {
            padding: 28px;
        }

        /* الحقول */
        .field-group {
            margin-bottom: 20px;
        }

        .field-label {
            display: block;
            font-size: 0.82rem;
            font-weight: 700;
            color: var(--text-secondary);
            margin-bottom: 8px;
            letter-spacing: 0.3px;
        }

        .field-wrap {
            position: relative;
        }

        .field-icon {
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            right: 14px;
            color: rgba(212,175,55,0.55);
            font-size: 1rem;
            pointer-events: none;
        }

        .field-input {
            width: 100%;
            padding: 12px 42px 12px 44px;
            background: var(--bg-input);
            border: 1px solid var(--border);
            color: var(--text-primary);
            border-radius: 14px;
            font-family: 'Cairo', sans-serif;
            font-size: 0.95rem;
            transition: border-color 0.2s, box-shadow 0.2s;
            outline: none;
        }

            .field-input::placeholder {
                color: var(--text-muted);
            }

            .field-input:focus {
                border-color: var(--gold);
                box-shadow: 0 0 0 3px rgba(212,175,55,0.12);
                background: var(--bg-input);
            }

        .toggle-pass {
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            left: 14px;
            background: none;
            border: none;
            color: var(--text-muted);
            cursor: pointer;
            padding: 4px;
            transition: color 0.2s;
            font-size: 1rem;
        }

            .toggle-pass:hover {
                color: var(--gold);
            }

        /* رسالة الخطأ */
        .error-msg {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 12px 16px;
            margin-bottom: 20px;
            background: rgba(229,57,53,0.10);
            border: 1px solid rgba(229,57,53,0.28);
            border-radius: 12px;
            color: #FF8A80;
            font-size: 0.88rem;
        }

            .error-msg i {
                font-size: 1rem;
                flex-shrink: 0;
            }

        /* زر الدخول */
        .btn-login {
            width: 100%;
            padding: 14px;
            background: linear-gradient(135deg, var(--gold-dark), var(--gold), var(--gold-light));
            background-size: 200% 100%;
            background-position: right;
            border: none;
            border-radius: 14px;
            color: #111;
            font-family: 'Cairo', sans-serif;
            font-size: 1rem;
            font-weight: 800;
            letter-spacing: 0.5px;
            cursor: pointer;
            box-shadow: 0 6px 24px rgba(212,175,55,0.3);
            transition: background-position 0.4s ease, box-shadow 0.3s ease, transform 0.2s ease;
        }

            .btn-login:hover {
                background-position: left;
                box-shadow: 0 8px 30px rgba(212,175,55,0.42);
                transform: translateY(-2px);
            }

            .btn-login:active {
                transform: translateY(0);
            }

            .btn-login:disabled {
                opacity: 0.6;
                cursor: not-allowed;
                transform: none;
            }

        /* الذيل */
        .card-foot {
            padding: 14px 28px 20px;
            text-align: center;
            border-top: 1px solid var(--border);
        }

            .card-foot span {
                font-size: 0.78rem;
                color: var(--text-muted);
            }
    </style>
</head>

<body>
    <div class="login-wrap">
        <div class="login-card">

            <!-- الجزء العلوي -->
            <div class="card-top">
                <div class="brand-logo">
                    @if (logo != null)
                    {
                        <img src="@logo" alt="شعار المتجر" />
                    }
                    else
                    {
                        <i class="bi bi-shield-lock-fill logo-icon"></i>
                    }
                </div>
                <h1 class="brand-title">@title</h1>
                <p class="brand-sub">تسجيل دخول الإدارة</p>
            </div>

            <!-- جسم البطاقة -->
            <div class="card-body">

                @if (!string.IsNullOrWhiteSpace(Model.Error))
                {
                    <div class="error-msg">
                        <i class="bi bi-exclamation-circle-fill"></i>
                        <span>@Model.Error</span>
                    </div>
                }

                <div class="gold-divider"><span></span></div>

                <form method="post">
                    <!-- البريد -->
                    <div class="field-group">
                        <label class="field-label">البريد الإلكتروني / اسم المستخدم</label>
                        <div class="field-wrap">
                            <i class="bi bi-person-fill field-icon"></i>
                            <input class="field-input"
                                   type="text"
                                   name="Email"
                                   value="@Model.Email"
                                   placeholder="أدخل البريد أو اسم المستخدم"
                                   autocomplete="username"
                                   required />
                        </div>
                    </div>

                    <!-- كلمة المرور -->
                    <div class="field-group">
                        <label class="field-label">كلمة المرور</label>
                        <div class="field-wrap">
                            <i class="bi bi-lock-fill field-icon"></i>
                            <input class="field-input"
                                   type="password"
                                   name="Password"
                                   id="passwordField"
                                   value="@Model.Password"
                                   placeholder="أدخل كلمة المرور"
                                   autocomplete="current-password"
                                   required />
                            <button type="button" class="toggle-pass" onclick="togglePassword()" id="toggleBtn" aria-label="إظهار/إخفاء كلمة المرور">
                                <i class="bi bi-eye-fill" id="eyeIcon"></i>
                            </button>
                        </div>
                    </div>

                    <button type="submit" class="btn-login">
                        <i class="bi bi-box-arrow-in-right me-2"></i>
                        دخول
                    </button>
                </form>
            </div>

            <!-- الذيل -->
            <div class="card-foot">
                <span>نظام إدارة المتجر &nbsp;·&nbsp; جميع الحقوق محفوظة</span>
            </div>

        </div>
    </div>

    <script>
        function togglePassword() {
          const field = document.getElementById('passwordField');
          const icon  = document.getElementById('eyeIcon');
          if (field.type === 'password') {
            field.type = 'text';
            icon.className = 'bi bi-eye-slash-fill';
          } else {
            field.type = 'password';
            icon.className = 'bi bi-eye-fill';
          }
        }
    </script>
</body>
</html>
