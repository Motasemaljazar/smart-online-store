@page
@model AdminDashboard.Pages.Admin.LiveMapModel

<style>
  .live-map-page { overflow-x: hidden; max-width: 100%; }
  .live-map-page #mapWrap { position: relative; border-radius: 20px; overflow: hidden; max-width: 100%; }
  .live-map-page #map { height: 65vh; min-height: 320px; width: 100%; }
  .live-map-toolbar { position: absolute; top: 14px; right: 14px; z-index: 1000; display: flex; flex-wrap: wrap; gap: 10px; align-items: center; max-width: calc(100% - 28px); }
  .live-map-toolbar .btn { border-radius: 12px; font-weight: 600; box-shadow: var(--shadow-sm); }
  .live-map-legend { position: absolute; bottom: 14px; right: 14px; z-index: 1000; background: rgba(255,255,255,.96); border-radius: 14px; padding: 12px 16px; box-shadow: var(--shadow-md); font-size: 0.8rem; backdrop-filter: blur(8px); max-width: calc(100% - 28px); }
  .live-map-legend .legend-item { display: flex; align-items: center; gap: 8px; margin-bottom: 6px; font-weight: 500; color: var(--brand-ink); }
  .live-map-legend .legend-item:last-child { margin-bottom: 0; }
  .live-map-legend .legend-dot { width: 12px; height: 12px; border-radius: 50%; box-shadow: 0 1px 3px rgba(0,0,0,.2); flex-shrink: 0; }
  .live-map-legend .legend-line { width: 24px; height: 4px; border-radius: 3px; flex-shrink: 0; }
  .live-map-status { font-size: 0.8rem; color: var(--brand-ink-light); display: flex; align-items: center; gap: 6px; }
  .live-map-status .pulse { width: 8px; height: 8px; border-radius: 50%; background: var(--brand-success); animation: live-map-pulse 2s infinite; }
  @@keyframes live-map-pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.5; } }
  .live-map-strip { display: flex; flex-wrap: wrap; gap: 12px; min-width: 0; }
  .live-map-order-card { min-width: 0; flex: 1 1 260px; max-width: 100%; cursor: pointer; padding: 14px 16px; border-radius: 14px; border: 2px solid transparent; transition: all 0.2s ease; background: var(--brand-surface); box-shadow: var(--shadow-sm); box-sizing: border-box; }
  .live-map-order-card:hover { border-color: rgba(211,47,47,.35); box-shadow: var(--shadow-md); transform: translateY(-2px); }
  .live-map-order-card.active-sel { border-color: var(--brand-primary); background: linear-gradient(135deg, rgba(211,47,47,.08), rgba(198,40,40,.06)); box-shadow: 0 0 0 1px var(--brand-primary); }
  .live-map-driver-card { min-width: 0; flex: 1 1 220px; max-width: 100%; cursor: pointer; padding: 12px 14px; border-radius: 12px; border: 2px solid transparent; transition: all 0.2s ease; background: var(--brand-surface); box-shadow: var(--shadow-sm); box-sizing: border-box; }
  .live-map-driver-card:hover { border-color: rgba(211,47,47,.25); box-shadow: var(--shadow-md); transform: translateY(-2px); }
  .live-map-driver-card.active-sel { border-color: var(--brand-primary); background: linear-gradient(135deg, rgba(211,47,47,.08), rgba(198,40,40,.06)); }
  .live-map-order-card .order-num { font-weight: 800; font-size: 1.05rem; color: var(--brand-ink); }
  .live-map-order-card .order-meta { font-size: 0.8rem; color: var(--brand-ink-light); margin-top: 4px; overflow: hidden; text-overflow: ellipsis; }
  .live-map-driver-card .driver-name { font-weight: 700; font-size: 0.95rem; }
  .live-map-driver-card .driver-meta { font-size: 0.75rem; color: var(--brand-ink-light); margin-top: 2px; overflow: hidden; text-overflow: ellipsis; }
  @@media (max-width: 576px) {
    .live-map-page #map { min-height: 280px; height: 55vh; }
    .live-map-order-card { flex: 1 1 100%; }
    .live-map-driver-card { flex: 1 1 100%; }
    .live-map-legend { font-size: 0.75rem; padding: 10px 12px; }
  }
</style>

<div class="live-map-page">
  <div class="admin-page-header">
    <div class="page-icon"><i class="bi bi-geo-alt-fill"></i></div>
    <div>
      <h1 class="page-title">الخريطة الحية</h1>
      <p class="page-subtitle">تتبع الطلبات النشطة ومواقع السائقين. انقر على طلب أو سائق للانتقال إلى الخريطة والتركيز عليه.</p>
    </div>
  </div>

  <div class="admin-card mb-4">
    <div id="mapWrap">
      <div id="map"></div>
      <div class="live-map-toolbar">
        <button type="button" class="btn btn-light btn-sm" id="btnClearSelection" style="display:none;" title="إلغاء التحديد وعرض الكل">
          <i class="bi bi-x-circle me-1"></i> إلغاء التحديد
        </button>
        <span class="live-map-status" id="liveMapStatus">
          <span class="pulse"></span> <span id="liveMapStatusText">جاري التحميل...</span>
        </span>
      </div>
      <div class="live-map-legend">
        <div class="legend-item"><span class="legend-dot" style="background:linear-gradient(135deg, #D32F2F, #C62828);"></span> المتجر</div>
        <div class="legend-item"><span class="legend-dot" style="background:linear-gradient(135deg, #1565C0, #0D47A1);"></span> عنوان التوصيل</div>
        <div class="legend-item"><span class="legend-dot" style="background:linear-gradient(135deg, #D32F2F, #B71C1C);"></span> طلبات نشطة</div>
        <div class="legend-item"><span class="legend-dot" style="background:linear-gradient(135deg, #2E7D32, #1B5E20);"></span> السائقون</div>
        <div class="legend-item"><span class="legend-line" style="background:linear-gradient(90deg, #D32F2F, #E53935);"></span> المسار</div>
      </div>
    </div>
  </div>

  <div class="row g-4">
    <div class="col-12" style="min-width:0;">
      <div class="admin-card" style="min-width:0;">
        <div class="admin-card-header d-flex flex-wrap align-items-center gap-2">
          <span><i class="bi bi-box-seam me-2"></i>الطلبات النشطة</span>
          <span class="badge bg-danger ms-2" id="ordersCountBadge">0</span>
        </div>
        <div class="admin-card-body py-3" style="min-width:0;overflow:hidden;">
          <div id="ordersList" class="live-map-strip">جاري التحميل...</div>
        </div>
      </div>
    </div>
    <div class="col-12" style="min-width:0;">
      <div class="admin-card" style="min-width:0;">
        <div class="admin-card-header">
          <span><i class="bi bi-people me-2"></i>السائقون</span>
        </div>
        <div class="admin-card-body py-3" style="min-width:0;overflow:hidden;">
          <div id="driverList" class="live-map-strip">جاري التحميل...</div>
        </div>
      </div>
    </div>
  </div>
</div>

@section Scripts {
<script>
// ─── MAP INIT ───────────────────────────────────────────────────────────────
const map = L.map('map', { attributionControl: false }).setView([33.5138, 36.2765], 12);

L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
  maxZoom: 19
}).addTo(map);

// ─── STATE ──────────────────────────────────────────────────────────────────
let storeMarker = null;
let routingProfile = 'driving';

let selectedOrderId = null;
let selectedDriverId = null;
/** عند true نضبط الخريطة (تكبير/تمركز) مرة واحدة فقط عند اختيار طلب، ثم يتحكم المستخدم */
let fitMapToSelectionOnce = false;

let selectedOrderMarker = null;
let selectedOrderRouteLine = null;
let selectedOrderTrack = null;
let selectedOrderRouteCache = { key: null, pts: null };

// Per-driver route line (driver → its target)
const driverRouteLines = new Map(); // driverId → L.polyline

// علامات الطلبات النشطة على الخريطة (مثل تطبيق الأدمن)
const orderMarkers = new Map(); // orderId → L.marker

// ─── OSRM ROUTE FETCH ───────────────────────────────────────────────────────
async function fetchOsrmRoute(fromLat, fromLng, toLat, toLng){
  try{
    const profile = (routingProfile === 'foot') ? 'foot' : 'driving';
    const url = `https://router.project-osrm.org/route/v1/${profile}/${fromLng},${fromLat};${toLng},${toLat}?overview=full&geometries=geojson`;
    const res = await fetch(url, { cache: 'no-store' });
    if(!res.ok) return null;
    const data = await res.json();
    const coords = data?.routes?.[0]?.geometry?.coordinates;
    if(!Array.isArray(coords) || coords.length < 2) return null;
    return coords.map(c=>[c[1], c[0]]);
  }catch(_){ return null; }
}

// ─── DRIVER TARGETS (destinations from backend) ────────────────────────────
const driverTargets = new Map();

// ─── DRIVER MARKERS + BREADCRUMB TRACKS ─────────────────────────────────────
const driverMarkers = new Map();
const driverTracks = new Map();     // driverId → L.polyline (breadcrumb)
const driverLastPts = new Map();    // driverId → [{lat,lng,t}]

async function ensureDriverTrack(driverId){
  if(driverTracks.has(driverId)) return;
  try{
    const res = await fetch(`/api/admin/driver-tracks/${driverId}?minutes=2`, { cache:'no-store' });
    if(!res.ok) return;
    const j = await res.json();
    const pts = (j.points || []).map(p=>({ lat: p.lat, lng: p.lng, t: new Date(p.createdAtUtc || p.createdAtUtc) }));
    driverLastPts.set(driverId, pts);
    const color = '#3b82f6';
    const line = L.polyline(pts.map(p=>[p.lat,p.lng]), { weight: 3, opacity: .55, color, dashArray: '6,8' }).addTo(map);
    driverTracks.set(driverId, line);
  }catch(_){ }
}

function trimLastPts(driverId){
  const arr = driverLastPts.get(driverId) || [];
  const cutoff = Date.now() - 2*60*1000;
  const kept = arr.filter(p => p.t && p.t.getTime() >= cutoff);
  driverLastPts.set(driverId, kept);
  return kept;
}

// ─── أيقونات الخريطة (متناسقة مع ثيم اللوحة) ─────────────────────────────────
function svgIcon(svg, w, h, ax, ay){
  return L.divIcon({ className: '', html: svg, iconSize: [w, h], iconAnchor: [ax, ay] });
}

const themeRed = '#D32F2F';
const themeRedDark = '#B71C1C';
const themeBlue = '#1565C0';
const themeGreen = '#2E7D32';

function storeIcon(){
  const svg = `<div style="filter:drop-shadow(0 2px 6px rgba(0,0,0,.25));">
    <svg xmlns="http://www.w3.org/2000/svg" width="44" height="44" viewBox="0 0 56 56">
      <defs><linearGradient id="restGrad" x1="0%" y1="0%" x2="100%" y2="100%"><stop offset="0%" style="stop-color:#D32F2F"/><stop offset="100%" style="stop-color:#B71C1C"/></linearGradient></defs>
      <circle cx="28" cy="28" r="26" fill="url(#restGrad)" stroke="#fff" stroke-width="3"/>
      <path d="M16 24h24v4H16zm4 6h16v14H20zm2 2v10h4V28zm8 0v10h4V28z" fill="#fff" opacity=".95"/>
      <path d="M22 18h4v6h-4zm8 0h4v6h-4zm-4 0h4v6h-4z" fill="#fff" opacity=".9"/>
    </svg></div>`;
  return svgIcon(svg, 44, 44, 22, 22);
}

function homeIcon(){
  const svg = `<div style="filter:drop-shadow(0 2px 6px rgba(0,0,0,.22));">
    <svg xmlns="http://www.w3.org/2000/svg" width="42" height="42" viewBox="0 0 52 52">
      <defs><linearGradient id="homeGrad" x1="0%" y1="0%" x2="100%" y2="100%"><stop offset="0%" style="stop-color:#1565C0"/><stop offset="100%" style="stop-color:#0D47A1"/></linearGradient></defs>
      <path d="M26 4L6 22v24h14V32h12v14h14V22z" fill="url(#homeGrad)" stroke="#fff" stroke-width="2.5"/>
      <circle cx="26" cy="26" r="4" fill="#fff" opacity=".9"/>
    </svg></div>`;
  return svgIcon(svg, 42, 42, 21, 21);
}

function orderPinIcon(orderId, status){
  const colors = { 4: '#1976D2', 3: '#F9A825', 7: '#F9A825', 2: '#FF8F00', default: '#D32F2F' };
  const c = colors[status] || colors.default;
  const svg = `<div style="text-align:center;filter:drop-shadow(0 2px 5px rgba(0,0,0,.2));">
    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="40" viewBox="0 0 32 40">
      <path d="M16 0C7.2 0 0 7.2 0 16c0 12 16 24 16 24s16-12 16-24C32 7.2 24.8 0 16 0z" fill="${c}" stroke="#fff" stroke-width="2"/>
      <circle cx="16" cy="16" r="6" fill="#fff"/>
    </svg>
    <div style="margin-top:-1px;font-size:11px;font-weight:800;background:#fff;padding:2px 6px;border-radius:6px;box-shadow:0 1px 4px rgba(0,0,0,.2);color:#212121;">#${orderId}</div>
  </div>`;
  return L.divIcon({ className: '', html: svg, iconSize: [48, 56], iconAnchor: [16, 40] });
}

function driverLabelIcon(driverName, driverId){
  const name = (driverName || 'سائق #' + driverId).substring(0, 18);
  const svg = `<div style="text-align:center;filter:drop-shadow(0 2px 5px rgba(0,0,0,.2));">
    <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 48 48">
      <defs><linearGradient id="drvGrad" x1="0%" y1="0%" x2="100%" y2="100%"><stop offset="0%" style="stop-color:#2E7D32"/><stop offset="100%" style="stop-color:#1B5E20"/></linearGradient></defs>
      <circle cx="24" cy="24" r="22" fill="url(#drvGrad)" stroke="#fff" stroke-width="2.5"/>
      <path d="M18 26h4l2-6h4l2 6h4v8h-4v-4h-8v4h-4z" fill="#fff"/>
      <circle cx="24" cy="18" r="4" fill="#fff"/>
    </svg>
    <div style="font-size:10px;font-weight:700;background:#fff;padding:2px 5px;border-radius:5px;box-shadow:0 1px 3px rgba(0,0,0,.18);max-width:88px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;margin-top:1px;">${name}</div>
  </div>`;
  return L.divIcon({ className: '', html: svg, iconSize: [88, 56], iconAnchor: [20, 28] });
}

function bikeIcon(headingDeg){
  const rot = (headingDeg || 0);
  const svg = `<div style="width:44px;height:44px;transform:rotate(${rot}deg);transform-origin:center;filter:drop-shadow(0 2px 5px rgba(0,0,0,.22));">
    <svg xmlns="http://www.w3.org/2000/svg" width="44" height="44" viewBox="0 0 56 56">
      <defs><linearGradient id="bikeGrad" x1="0%" y1="0%" x2="100%" y2="100%"><stop offset="0%" style="stop-color:#2E7D32"/><stop offset="100%" style="stop-color:#1B5E20"/></linearGradient></defs>
      <circle cx="18" cy="44" r="10" fill="#1a1a1a" stroke="#fff" stroke-width="2"/>
      <circle cx="42" cy="44" r="10" fill="#1a1a1a" stroke="#fff" stroke-width="2"/>
      <path d="M24 32h8l4 8h-6l-2-4h-4z" fill="url(#bikeGrad)"/>
      <path d="M32 24h6l4 8" stroke="#1a1a1a" stroke-width="3" fill="none" stroke-linecap="round"/>
      <circle cx="38" cy="20" r="4" fill="url(#bikeGrad)" stroke="#fff" stroke-width="1.5"/>
    </svg>
  </div>`;
  return svgIcon(svg, 44, 44, 22, 22);
}

// ─── HELPERS ────────────────────────────────────────────────────────────────
function statusText(s){
  switch(s){
    case 0: return 'جديد';
    case 1: return 'قيد المراجعة';
    case 2: return 'قيد التحضير';
    case 3: return 'جاهز';
    case 7: return 'تم القبول';
    case 4: return 'مع السائق';
    case 5: return 'تم التسليم';
    case 6: return 'ملغى';
    default: return String(s);
  }
}

function statusBadgeClass(s){
  if(s===4) return 'text-bg-warning';
  if(s===3||s===7) return 'text-bg-info';
  if(s===5) return 'text-bg-success';
  if(s===6) return 'text-bg-danger';
  return 'text-bg-primary';
}

// ─── SIDEBAR: DRIVERS ───────────────────────────────────────────────────────
// Cached driver info for sidebar updates
let cachedDrivers = [];

async function loadSidebar(){
  try {
    const res = await fetch('/api/admin/drivers');
    if(!res.ok) return;
    cachedDrivers = await res.json();
    renderDriverSidebar();
  } catch(_){}
}

function renderDriverSidebar(){
  const driverOrderCount = new Map();
  const driverOrderIds = new Map();
  (lastLiveOrders || []).forEach(o => {
    if(o.driverId){
      driverOrderCount.set(o.driverId, (driverOrderCount.get(o.driverId)||0)+1);
      if(!driverOrderIds.has(o.driverId)) driverOrderIds.set(o.driverId, []);
      driverOrderIds.get(o.driverId).push(o.id);
    }
  });

  const html = cachedDrivers.map(d=>{
    const count = driverOrderCount.get(d.id) || 0;
    const orderIds = driverOrderIds.get(d.id) || [];
    const target = driverTargets.get(d.id);
    const targetLabel = target ? target.targetLabel : '';
    const isSel = (selectedDriverId === d.id);
    const statusText = ['متاح','مشغول','غير متاح'][d.status]||d.status||'';

    return `<div class="live-map-driver-card ${isSel?'active-sel':''}" id="driverRow-${d.id}" data-id="${d.id}">
      <div class="driver-name">سائق #${d.id} — ${d.name||'—'}</div>
      <div class="driver-meta">
        <span class="badge text-bg-secondary me-1">${statusText}</span>
        <span id="driverSpeed-${d.id}">— كم/س</span>
        <span class="me-1">• طلبات: ${count}</span>
        ${targetLabel ? `<span class="text-truncate d-inline-block" style="max-width:120px" title="${targetLabel}">→ ${targetLabel}</span>` : ''}
      </div>
      ${orderIds.length ? `<div class="text-muted mt-1" style="font-size:.7rem;">${orderIds.map(id=>'#'+id).join(' • ')}</div>` : ''}
    </div>`;
  }).join('');

  document.getElementById('driverList').innerHTML = html || '<div class="text-muted small">لا يوجد سائقون</div>';

  document.querySelectorAll('.live-map-driver-card').forEach(el=>{
    el.addEventListener('click', ()=>{
      const did = parseInt(el.getAttribute('data-id'));
      if(selectedDriverId === did){ selectedDriverId = null; selectedOrderId = null; }
      else { selectedDriverId = did; selectedOrderId = null; }
      scrollMapIntoView();
      setTimeout(()=>{ clearSelectedOrderLayers(); refreshLiveMap(); }, 380);
    });
  });
}

// ─── CACHE for last live-map orders (used by sidebar) ───────────────────────
let lastLiveOrders = [];

function scrollMapIntoView(){
  const wrap = document.getElementById('mapWrap');
  if(wrap) wrap.scrollIntoView({ behavior: 'smooth', block: 'center' });
}

// ─── SIDEBAR: ORDERS (بطاقات أفقية) ─────────────────────────────────────────
function renderOrderSidebar(orders){
  lastLiveOrders = orders;

  const htmlOrders = orders.length ? orders.map(o=>{
    const d = o.driverId ? `سائق #${o.driverId}` : 'بدون سائق';
    const isSel = (selectedOrderId === o.id);
    const addr = (o.deliveryAddress || '').substring(0, 45);
    return `<div class="live-map-order-card ${isSel?'active-sel':''}" data-id="${o.id}">
      <div class="order-num">طلب #${o.id} <span class="badge ${statusBadgeClass(o.currentStatus)} badge-status ms-1">${statusText(o.currentStatus)}</span></div>
      <div class="order-meta">${d} • ${(o.customerName||'').substring(0,20)}${(o.customerName||'').length>20?'…':''}</div>
      <div class="order-meta text-truncate" title="${o.deliveryAddress||''}">${addr}${addr.length>=45?'…':''}</div>
    </div>`;
  }).join('') : '<div class="text-muted">لا يوجد طلبات نشطة</div>';

  document.getElementById('ordersList').innerHTML = htmlOrders;
  const badge = document.getElementById('ordersCountBadge');
  if(badge) badge.textContent = orders.length;

  document.querySelectorAll('.live-map-order-card').forEach(el=>{
    el.addEventListener('click', ()=>{
      const id = parseInt(el.getAttribute('data-id'));
      selectedOrderId = id;
      const order = orders.find(x=>x.id===id);
      selectedDriverId = order?.driverId ?? null;
      fitMapToSelectionOnce = true;
      scrollMapIntoView();
      clearSelectedOrderLayers();
      setTimeout(()=>{
        refreshLiveMap();
        if(!order?.driverId) loadOrderTrack(id);
      }, 380);
    });
  });

  renderDriverSidebar();
}

// ─── CLEAR SELECTED ORDER LAYERS ────────────────────────────────────────────
function clearSelectedOrderLayers(){
  try{ if(selectedOrderMarker){ map.removeLayer(selectedOrderMarker); } }catch(_){ }
  try{ if(selectedOrderRouteLine){ map.removeLayer(selectedOrderRouteLine); } }catch(_){ }
  try{ if(selectedOrderTrack){ map.removeLayer(selectedOrderTrack); } }catch(_){ }
  selectedOrderMarker = null;
  selectedOrderRouteLine = null;
  selectedOrderTrack = null;
  selectedOrderRouteCache = { key: null, pts: null };
}

// ─── PRUNE DRIVER LAYERS (show only selected driver when one is chosen) ────
function pruneDriverLayers(){
  if(selectedDriverId == null) return;
  for(const [id,m] of driverMarkers){
    if(id !== selectedDriverId){ try{ map.removeLayer(m); }catch(_){ } driverMarkers.delete(id); }
  }
  for(const [id,l] of driverTracks){
    if(id !== selectedDriverId){ try{ map.removeLayer(l); }catch(_){ } driverTracks.delete(id); }
  }
  for(const [id,l] of driverRouteLines){
    if(id !== selectedDriverId){ try{ map.removeLayer(l); }catch(_){ } driverRouteLines.delete(id); }
  }
  driverLastPts.forEach((_, id)=>{ if(id !== selectedDriverId) driverLastPts.delete(id); });
}

// ─── MAIN REFRESH (called every 5s) ─────────────────────────────────────────
async function refreshLiveMap(){
  const res = await fetch('/api/admin/live-map');
  if(!res.ok){
    const ol = document.getElementById('ordersList');
    if(ol){ ol.innerHTML = '<div class="text-danger small">فشل تحميل بيانات الخريطة</div>'; }
    return;
  }
  const data = await res.json();

  // Update driver targets cache
  driverTargets.clear();
  (data.driverTargets || []).forEach(t=>{ driverTargets.set(t.driverId, t); });

  // Store marker
  const r = data.store;
  routingProfile = (r && r.routingProfile) ? String(r.routingProfile) : 'driving';
  if(r && r.lat && r.lng){
    const pos = [r.lat, r.lng];
    if(!storeMarker){
      storeMarker = L.marker(pos, { icon: storeIcon() }).addTo(map);
      storeMarker.bindPopup(`المتجر: ${r.name || ''}`);
      map.setView(pos, 14);
    } else {
      storeMarker.setLatLng(pos);
    }
  }

  const orders = data.orders || [];

  // If selected order no longer exists, reset selection
  if(selectedOrderId != null && !orders.some(x=>x.id === selectedOrderId)){
    selectedOrderId = null;
    selectedDriverId = null;
    clearSelectedOrderLayers();
  }

  // If selected driver no longer has orders, keep marker but allow deselect via sidebar click.

  if(selectedOrderId != null){
    const o = orders.find(x=>x.id === selectedOrderId);
    if(o) selectedDriverId = o.driverId ?? null;
    pruneDriverLayers();

    if(o && o.deliveryLat && o.deliveryLng){
      const p = [o.deliveryLat, o.deliveryLng];
      if(!selectedOrderMarker){
        selectedOrderMarker = L.marker(p, { icon: homeIcon() }).addTo(map);
        selectedOrderMarker.bindPopup(`طلب #${o.id}<br/>${o.customerName||''}<br/>${o.deliveryAddress || ''}`);
      } else {
        selectedOrderMarker.setLatLng(p);
        selectedOrderMarker.setPopupContent(`طلب #${o.id}<br/>${o.customerName||''}<br/>${o.deliveryAddress || ''}`);
      }

      // Route: فقط من السائق إلى مكان الطلب إن وُجد سائق
      const driverLocsNow = data.driverLocations || [];
      const driverLoc = selectedDriverId ? driverLocsNow.find(l=> l.driverId === selectedDriverId) : null;
      if(driverLoc && driverLoc.lat != null && driverLoc.lng != null){
        const fromLat = driverLoc.lat, fromLng = driverLoc.lng;
        const key = `driver-${fromLat.toFixed(5)},${fromLng.toFixed(5)}->${p[0].toFixed(5)},${p[1].toFixed(5)}`;
        let pts = (selectedOrderRouteCache.key === key) ? selectedOrderRouteCache.pts : null;
        if(!pts){
          const fetched = await fetchOsrmRoute(fromLat, fromLng, p[0], p[1]);
          pts = fetched || [[fromLat, fromLng], p];
          selectedOrderRouteCache = { key, pts };
        }
        const lineColor = (typeof isNight !== 'undefined' && isNight) ? '#E53935' : '#D32F2F';
        if(!selectedOrderRouteLine){
          selectedOrderRouteLine = L.polyline(pts, { weight: 5, opacity: .88, color: lineColor }).addTo(map);
        } else {
          selectedOrderRouteLine.setLatLngs(pts);
          selectedOrderRouteLine.setStyle({ color: lineColor });
        }
      } else {
        try{ if(selectedOrderRouteLine){ map.removeLayer(selectedOrderRouteLine); } }catch(_){}
        selectedOrderRouteLine = null;
        selectedOrderRouteCache = { key: null, pts: null };
      }
    }
  } else if(selectedDriverId != null){
    // Driver selected but no order — just show driver + route
    pruneDriverLayers();
  } else {
    // Nothing selected: clear order layers, show all drivers
    clearSelectedOrderLayers();
    // Remove per-driver route lines when nothing selected (they are rendered per SignalR update)
  }

  // ─── علامات الطلبات النشطة: عند اختيار طلب نعرض على الخريطة الطلب المختار فقط
  const orderIds = new Set((orders || []).map(x => x.id));
  if (selectedOrderId != null) {
    for (const [oid, om] of orderMarkers) {
      try { map.removeLayer(om); } catch (_) {}
      orderMarkers.delete(oid);
    }
  } else {
    for (const [oid, om] of orderMarkers) {
      if (!orderIds.has(oid)) {
        try { map.removeLayer(om); } catch (_) {}
        orderMarkers.delete(oid);
      }
    }
  }
  (orders || []).forEach(o => {
    if (!o.deliveryLat || !o.deliveryLng) return;
    if (selectedOrderId != null && o.id !== selectedOrderId) return;
    let m = orderMarkers.get(o.id);
    const pos = [o.deliveryLat, o.deliveryLng];
    if (!m) {
      m = L.marker(pos, { icon: orderPinIcon(o.id, o.currentStatus) }).addTo(map);
      m.bindPopup(`طلب #${o.id}<br/>${o.customerName || ''}<br/>${o.deliveryAddress || ''}`);
      orderMarkers.set(o.id, m);
    } else {
      m.setLatLng(pos);
      m.setIcon(orderPinIcon(o.id, o.currentStatus));
    }
  });

  // ─── علامات السائقين النشطين من بيانات الـ API (تظهر حتى بدون SignalR)
  const driverLocs = data.driverLocations || [];
  driverLocs.forEach(loc => {
    if (selectedDriverId != null && loc.driverId !== selectedDriverId) return;
    const pos = [loc.lat, loc.lng];
    let m = driverMarkers.get(loc.driverId);
    if (!m) {
      m = L.marker(pos, { icon: driverLabelIcon(loc.driverName, loc.driverId) }).addTo(map);
      m.bindPopup(loc.driverName ? `سائق: ${loc.driverName}` : `سائق #${loc.driverId}`);
      driverMarkers.set(loc.driverId, m);
    } else {
      m.setLatLng(pos);
      // لا نغيّر الأيقونة من الـ API لئلا نطمس أيقونة الدراجة من SignalR
    }
  });

  // ضبط الخريطة مرة واحدة فقط بعد اختيار الطلب، ثم يتحكم المستخدم بالتكبير/التحريك
  if (fitMapToSelectionOnce && selectedOrderId != null && selectedOrderMarker) {
    fitMapToSelectionOnce = false;
    const dm = selectedDriverId ? driverMarkers.get(selectedDriverId) : null;
    if (dm) {
      try {
        map.fitBounds(L.latLngBounds([selectedOrderMarker.getLatLng(), dm.getLatLng()]), { padding: [50, 50] });
      } catch (_) {}
    } else {
      try { map.setView(selectedOrderMarker.getLatLng(), 15); } catch (_) {}
    }
  }

  renderOrderSidebar(orders);
  updateLiveMapToolbar();
}

function updateLiveMapToolbar(){
  const btn = document.getElementById('btnClearSelection');
  const statusEl = document.getElementById('liveMapStatusText');
  if(btn) btn.style.display = (selectedOrderId != null || selectedDriverId != null) ? 'inline-flex' : 'none';
  if(statusEl) statusEl.textContent = lastLiveOrders.length ? `تحديث تلقائي كل 5 ثوان • ${lastLiveOrders.length} طلب نشط` : 'تحديث تلقائي كل 5 ثوان';
}

// ─── LOAD ORDER TRACK (historical path for a completed/active order) ───────
async function loadOrderTrack(orderId){
  try{
    const res = await fetch(`/api/admin/order-tracks/${orderId}`, { cache:'no-store' });
    if(!res.ok) return;
    const j = await res.json();
    const pts = (j.points || []).map(p=>[p.lat, p.lng]);
    if(selectedOrderTrack){ try{ map.removeLayer(selectedOrderTrack); }catch(_){ } selectedOrderTrack = null; }
    if(pts.length >= 2){
      const color = (typeof isNight !== 'undefined' && isNight) ? '#f59e0b' : '#ea580c';
      selectedOrderTrack = L.polyline(pts, { weight: 4, opacity: .8, color, dashArray: '8,6' }).addTo(map);
      if(selectedOrderId == null) try{ map.fitBounds(selectedOrderTrack.getBounds(), { padding:[40,40] }); }catch(_){ }
    }
  }catch(_){ }
}

// ─── DRAW/UPDATE PER-DRIVER ROUTE LINE (driver → its current target) ───────
async function updateDriverRouteLine(driverId, driverLat, driverLng){
  const t = driverTargets.get(driverId);
  if(!t || !t.targetLat || !t.targetLng) return;

  const key = `${driverLat.toFixed(4)},${driverLng.toFixed(4)}->${t.targetLat.toFixed(4)},${t.targetLng.toFixed(4)}`;
  // Throttle: only re-fetch route if driver moved meaningfully
  const existing = driverRouteLines.get(driverId);
  if(existing && existing._cacheKey === key) return;

  const pts = await fetchOsrmRoute(driverLat, driverLng, t.targetLat, t.targetLng);
  const lineColor = isNight ? '#22d3ee' : '#10b981';
  const linePts = pts || [[driverLat, driverLng], [t.targetLat, t.targetLng]];

  if(existing){
    existing.setLatLngs(linePts);
    existing.setStyle({ color: lineColor });
    existing._cacheKey = key;
  } else {
    const line = L.polyline(linePts, { weight: 3, opacity: .7, color: lineColor, dashArray: '10,6' }).addTo(map);
    line._cacheKey = key;
    driverRouteLines.set(driverId, line);
  }
}

// ─── SIGNALR: LIVE DRIVER LOCATION ─────────────────────────────────────────
const tracking = new signalR.HubConnectionBuilder().withUrl('/hubs/tracking').withAutomaticReconnect().build();

tracking.on('driver_location', payload => {
  const { driverId, lat, lng, speedMps, headingDeg, accuracyMeters, updatedAtUtc } = payload;

  // If a specific driver is selected, ignore updates from others
  if(selectedDriverId != null && driverId !== selectedDriverId) return;

  const pos = [lat, lng];

  // Marker
  let m = driverMarkers.get(driverId);
  if(!m){
    m = L.marker(pos, { icon: bikeIcon(headingDeg) }).addTo(map);
    m.bindPopup('...');
    driverMarkers.set(driverId, m);
    driverLastPts.set(driverId, []);
    ensureDriverTrack(driverId);
  } else {
    m.setLatLng(pos);
    m.setIcon(bikeIcon(headingDeg));
  }

  // Breadcrumbs: keep last 2 minutes
  const arr = driverLastPts.get(driverId) || [];
  arr.push({ lat, lng, t: new Date(updatedAtUtc || Date.now()) });
  driverLastPts.set(driverId, arr);
  const kept = trimLastPts(driverId);
  let line = driverTracks.get(driverId);
  const crumbColor = isNight ? '#22d3ee' : '#3b82f6';
  if(!line){
    line = L.polyline(kept.map(p=>[p.lat,p.lng]), { weight: 3, opacity: .55, color: crumbColor, dashArray: '6,8' }).addTo(map);
    driverTracks.set(driverId, line);
  } else {
    line.setLatLngs(kept.map(p=>[p.lat,p.lng]));
    line.setStyle({ color: crumbColor });
  }

  // Popup: rich driver details
  const kmhVal = Math.max(0, Math.min(160, (speedMps || 0) * 3.6));
  const kmh = kmhVal.toFixed(1);
  const upd = new Date(updatedAtUtc);
  const sinceSec = Math.max(0, Math.floor((Date.now() - upd.getTime()) / 1000));
  const acc = (accuracyMeters || 0).toFixed(0);
  const t = driverTargets.get(driverId);
  const destLine = t && t.targetLabel ? `<br/>📍 متجه إلى: <b>${t.targetLabel}</b>` : '';
  const orderLine = t && t.orderId ? `<br/>📦 الطلب: #${t.orderId}` : '';
  m.setPopupContent(`<b>سائق #${driverId}</b><br/>🚗 ${kmh} كم/س • دقة ${acc}م<br/>🧭 اتجاه: ${(headingDeg||0).toFixed(0)}°${destLine}${orderLine}<br/>🕐 آخر تحديث: منذ ${sinceSec} ث`);

  // Update speed badge in sidebar
  const el = document.getElementById(`driverSpeed-${driverId}`);
  if(el) el.textContent = `${kmh} كم/س`;

  // عند اختيار طلب: تحديث مسار السائق → مكان الطلب
  if (selectedOrderId != null && driverId === selectedDriverId) {
    const o = (lastLiveOrders || []).find(x => x.id === selectedOrderId);
    if (o && o.deliveryLat != null && o.deliveryLng != null) {
      (async () => {
        const pts = await fetchOsrmRoute(lat, lng, o.deliveryLat, o.deliveryLng);
        const linePts = pts || [[lat, lng], [o.deliveryLat, o.deliveryLng]];
        const lineColor = (typeof isNight !== 'undefined' && isNight) ? '#E53935' : '#D32F2F';
        if (selectedOrderRouteLine) {
          selectedOrderRouteLine.setLatLngs(linePts);
          selectedOrderRouteLine.setStyle({ color: lineColor });
        } else {
          selectedOrderRouteLine = L.polyline(linePts, { weight: 5, opacity: .88, color: lineColor }).addTo(map);
        }
      })();
    }
  } else {
    updateDriverRouteLine(driverId, lat, lng);
  }
});

// ─── INIT ───────────────────────────────────────────────────────────────────
let liveMapIntervalId = null;
const LIVE_MAP_INTERVAL_MS = 5000;

function startLiveMapInterval(){
  if(liveMapIntervalId != null) return;
  liveMapIntervalId = setInterval(async ()=>{ await refreshLiveMap(); }, LIVE_MAP_INTERVAL_MS);
}
function stopLiveMapInterval(){
  if(liveMapIntervalId != null){ clearInterval(liveMapIntervalId); liveMapIntervalId = null; }
}

document.addEventListener('visibilitychange', ()=>{
  if(document.hidden){
    stopLiveMapInterval();
  } else {
    refreshLiveMap().then(()=> startLiveMapInterval());
  }
});

document.getElementById('btnClearSelection').addEventListener('click', ()=>{
  selectedOrderId = null;
  selectedDriverId = null;
  fitMapToSelectionOnce = false;
  clearSelectedOrderLayers();
  refreshLiveMap();
});

(async ()=>{
  // قراءة orderId و driverId من URL (قادمة من صفحة الطلبات)
  const _urlParams = new URLSearchParams(window.location.search);
  const _urlOrderId  = parseInt(_urlParams.get('orderId')  || '0') || null;
  const _urlDriverId = parseInt(_urlParams.get('driverId') || '0') || null;
  if(_urlOrderId){
    selectedOrderId    = _urlOrderId;
    selectedDriverId   = _urlDriverId;
    fitMapToSelectionOnce = true;
  }
  await loadSidebar();
  await refreshLiveMap();
  if(!document.hidden) startLiveMapInterval();
  setInterval(loadSidebar, 30000);
  tracking.start().then(()=> tracking.invoke('JoinAdmin')).catch(err => console.error(err));
})();
</script>
}
